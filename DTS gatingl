-- ── Target selection ──────────────────────────────────────────────────────────
local modeNames = { "Farthest", "First", "Strongest", "SmartAmmo" }

local function getEnemyRoot(model)
    return model:FindFirstChild("HumanoidRootPart")
        or model:FindFirstChild("Hitbox")
        or model.PrimaryPart
        or model:FindFirstChildWhichIsA("BasePart")
end

local function getTarget()
    local mode     = getgenv().targetMode
    local modeName = modeNames[mode]
    local target   = nil
    local best     = (modeName == "Farthest" or modeName == "Strongest")
                     and -math.huge or math.huge

    for _, model in ipairs(NPCs:GetChildren()) do
        if model:IsA("Model") and not Players:GetPlayerFromCharacter(model) then
            local rp = model:FindFirstChild("RootPointer")
            if rp and rp.Value then
                local folder   = rp.Value
                local fakeUnit = folder:GetAttribute("FakeUnit")
                local unitType = folder:GetAttribute("Type")
                local hp       = folder:GetAttribute("Health") or 0

                if fakeUnit == false and unitType == "Enemies" and hp > 0 then
                    local root = getEnemyRoot(model)
                    if root then
                        local dist = (root.Position - camera.CFrame.Position).Magnitude
                        if dist <= getgenv().maxRange then
                            if modeName == "Farthest" and dist > best then
                                best = dist; target = root
                            elseif modeName == "First" and dist < best then
                                best = dist; target = root
                            elseif modeName == "Strongest" and hp > best then
                                best = hp; target = root
                            elseif modeName == "SmartAmmo" and hp < best then
                                best = hp; target = root
                            end
                        end
                    end
                end
            end
        end
    end

    return target
end

-- ── Accuracy: predict với velocity + server ping compensation ─────────────────
local function getPredictedPos(enemy)
    local ping = (LocalPlayer:GetNetworkPing and LocalPlayer:GetNetworkPing()) or 0.05
    local vel  = enemy.AssemblyLinearVelocity

    -- Lead time: ping round-trip + half bullet travel
    local dist     = (enemy.Position - camera.CFrame.Position).Magnitude
    local leadTime = ping + (dist / 150)  -- 150 = bullet speed estimate

    local predicted = enemy.Position + vel * leadTime
    return Vector3.new(predicted.X, predicted.Y, predicted.Z)
end

-- ── Fire packet ───────────────────────────────────────────────────────────────
local function sendFirePacket()
    if not getgenv().auto_fire or isReloading then return end

    local enemy = getTarget()
    if not enemy then
        bulletCounter = 0
        return
    end

    -- Reload check từ Replicator (hook 1 cấp data)
    local needReload = false

    if currentReplicator then
        pcall(function()
            local minigun = currentReplicator:Get("Minigun")
            local canFire = currentReplicator:Get("CanFire")
            if minigun and canFire == false then
                needReload = true
            end
        end)
    end

    if bulletCounter >= 250 then
        needReload = true
    end

    if needReload then
        isReloading   = true
        bulletCounter = 0

        task.spawn(function()
            -- Gửi reload request
            pcall(function()
                reReload:FireServer()
            end)

            -- ── Hook 2 wait: đợi server confirm hoặc fallback 2s ─────────────
            local done  = false
            local conn  = reloadComplete.Event:Connect(function()
                done = true
            end)

            local deadline = tick() + 2.5  -- fallback timeout
            while not done and tick() < deadline do
                task.wait(0.05)
            end
            conn:Disconnect()

            -- Đợi thêm một tick để CanFire cập nhật trước khi bắn lại
            task.wait(0.05)
            isReloading = false
        end)
        return
    end

    -- Fire với prediction
    local targetPos  = getPredictedPos(enemy)
    local sync       = workspace:GetAttribute("Sync") or 0
    local serverTime = workspace:GetServerTimeNow()

    bulletCounter += 1

    for i = 1, getgenv().multiplytimes do
        pcall(function()
            GatlingChannel:fireServer(
                "Fire",
                vector.create(targetPos.X, targetPos.Y, targetPos.Z),
                sync,
                serverTime + (i * 0.0005)
            )
        end)
    end
end

task.spawn(function()
    while true do
        task.wait(getgenv().gatlingcooldown)
        if getgenv().auto_fire then
            sendFirePacket()
        end
    end
end)

