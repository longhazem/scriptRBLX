local trackedNPCs     = {}
local trackedGatlings = {}

local function getNPCHealth(folder)
    return folder:GetAttribute("Health") or 0
end

local function isValidNPC(model)
    if not model or not model.Parent then return false end
    if not model:IsA("Model") then return false end
    local rp = model:FindFirstChild("RootPointer")
    if not rp or not rp.Value then return false end
    local folder   = rp.Value
    local fakeUnit = folder:GetAttribute("FakeUnit")
    local unitType = folder:GetAttribute("Type")
    if fakeUnit ~= false then return false end
    if unitType ~= "Enemies" then return false end
    if getNPCHealth(folder) <= 0 then return false end
    return true
end

local function getEnemyRoot(model)
    return model:FindFirstChild("HumanoidRootPart")
        or model:FindFirstChild("Hitbox")
        or model.PrimaryPart
        or model:FindFirstChildWhichIsA("BasePart")
end

local function registerNPC(model)
    if not isValidNPC(model) then return end
    local rp   = model:FindFirstChild("RootPointer")
    local root = getEnemyRoot(model)
    if not root then return end
    trackedNPCs[model] = { folder = rp.Value, root = root }
end

local function unregisterNPC(model)   trackedNPCs[model] = nil end

local function registerGatling(model)
    task.wait(0.3)
    if not model or not model.Parent then return end
    local tr = model:FindFirstChild("TowerReplicator")
    if not tr then return end
    if tr:GetAttribute("Name") == "Gatling Gun" then
        trackedGatlings[model] = tr
    end
end

local function unregisterGatling(model) trackedGatlings[model] = nil end

for _, model in ipairs(NPCs:GetChildren()) do registerNPC(model) end
for _, model in ipairs(Workspace_Towers:GetChildren()) do
    local tr = model:FindFirstChild("TowerReplicator")
    if tr and tr:GetAttribute("Name") == "Gatling Gun" then
        trackedGatlings[model] = tr
    end
end

NPCs.ChildAdded:Connect(registerNPC)
NPCs.ChildRemoved:Connect(unregisterNPC)
Workspace_Towers.ChildAdded:Connect(registerGatling)
Workspace_Towers.ChildRemoved:Connect(unregisterGatling)

-- Stale purge every 0.5s
task.spawn(function()
    while true do
        task.wait(0.5)
        for model, entry in pairs(trackedNPCs) do
            if not model.Parent
            or not entry.root.Parent
            or getNPCHealth(entry.folder) <= 0
            or not isValidNPC(model) then
                trackedNPCs[model] = nil
            end
        end
    end
end)

local function getTarget()
    local mode    = getgenv().targetMode
    local best    = nil
    local bestVal = nil

    for model, entry in pairs(trackedNPCs) do
        local root   = entry.root
        local folder = entry.folder

        if not model.Parent or not root.Parent then
            trackedNPCs[model] = nil
        else
            local hp = getNPCHealth(folder)
            if hp <= 0 then
                trackedNPCs[model] = nil
            else
                local pos = root.Position

                if mode == 1 then
                    local myPos = LocalPlayer.Character
                        and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                        and LocalPlayer.Character.HumanoidRootPart.Position
                        or Vector3.zero
                    local dist = (pos - myPos).Magnitude
                    if bestVal == nil or dist > bestVal then bestVal = dist; best = root end

                elseif mode == 2 then
                    local idx = model:GetAttribute("PathIndex") or 0
                    if bestVal == nil or idx > bestVal then bestVal = idx; best = root end

                elseif mode == 3 then
                    if bestVal == nil or hp > bestVal then bestVal = hp; best = root end

                elseif mode == 4 then
                    if bestVal == nil or hp < bestVal then bestVal = hp; best = root end
                end
            end
        end
    end

    return best
end

local function syncAllGatlings(target)
    local sync       = workspace:GetAttribute("Sync") or 0
    local serverTime = workspace:GetServerTimeNow()
    local pos        = target.Position

    for _, tr in pairs(trackedGatlings) do
        for i = 1, getgenv().multiplytimes do
            pcall(function()
                GatlingChannel:fireServer(
                    "Fire",
                    vector.create(pos.X, pos.Y, pos.Z),
                    sync,
                    serverTime + (i * 0.0008)
                )
            end)
        end
    end
end

task.spawn(function()
    while true do
        task.wait(getgenv().gatlingcooldown)
        if getgenv().auto_fire then
            local target = getTarget()
            if target then syncAllGatlings(target) end
        end
    end
end)

