local function setFPSMode(enabled)
    getgenv().fps_mode = enabled
    pcall(function()
        remoteFunc:InvokeServer(
            "Troops", "Abilities", "Activate",
            {
                Troop = workspace:WaitForChild("Towers"):WaitForChild("Default"),
                Name  = "FPS",
                Data  = { enabled = enabled }
            }
        )
    end)
    print("[TokaiHub] FPS Mode:", enabled and "ON" or "OFF")
end

