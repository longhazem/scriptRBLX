end

local function makeLabel(parent, text)
    local lbl = Instance.new("TextLabel")
    lbl.Size               = UDim2_New(0.65, 0, 1, 0)
    lbl.Position           = UDim2_New(0, 12, 0, 0)
    lbl.BackgroundTransparency = 1
