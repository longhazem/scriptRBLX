-- ── Target tracking ───────────────────────────────────────────────────────────
local trackedNPCs     = {}
local trackedGatlings = {}

local function isValidNPC(model)
    if not model:IsA("Model") then return false end
    local rp = model:FindFirstChild("RootPointer")
    if not rp or not rp.Value then return false end
    return not rp.Value:GetAttribute("FakeUnit")
end

local function registerNPC(model)
    if not isValidNPC(model) then return end
    local rp = model:FindFirstChild("RootPointer")
    trackedNPCs[model] = rp.Value
end

local function unregisterNPC(model)
    trackedNPCs[model] = nil
end

local function registerGatling(model)
    task.wait(0.3)
    local tr = model:FindFirstChild("TowerReplicator")
    if not tr then return end
    if tr:GetAttribute("Name") == "Gatling Gun" then
        trackedGatlings[model] = tr
    end
end

local function unregisterGatling(model)
    trackedGatlings[model] = nil
end

for _, model in ipairs(NPCs:GetChildren()) do
    registerNPC(model)
end

for _, model in ipairs(Workspace_Towers:GetChildren()) do
    local tr = model:FindFirstChild("TowerReplicator")
    if tr and tr:GetAttribute("Name") == "Gatling Gun" then
        trackedGatlings[model] = tr
    end
end

NPCs.ChildAdded:Connect(registerNPC)
NPCs.ChildRemoved:Connect(unregisterNPC)
Workspace_Towers.ChildAdded:Connect(registerGatling)
Workspace_Towers.ChildRemoved:Connect(unregisterGatling)

-- ── Target selection ──────────────────────────────────────────────────────────
local function getTarget()
    local mode    = getgenv().targetMode
    local best    = nil
    local bestVal = nil

    for model, rootPart in pairs(trackedNPCs) do
        if rootPart and rootPart.Parent then
            local humanoid = model:FindFirstChildOfClass("Humanoid")
            local hp       = humanoid and humanoid.Health or 0
            local pos      = rootPart.Position

            if mode == 1 then
                local myPos = LocalPlayer.Character
                    and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                    and LocalPlayer.Character.HumanoidRootPart.Position
                    or Vector3.zero
                local dist = (pos - myPos).Magnitude
                if bestVal == nil or dist > bestVal then
                    bestVal = dist; best = rootPart
                end
            elseif mode == 2 then
                local idx = model:GetAttribute("PathIndex") or 0
                if bestVal == nil or idx > bestVal then
                    bestVal = idx; best = rootPart
                end
            elseif mode == 3 then
                if bestVal == nil or hp > bestVal then
                    bestVal = hp; best = rootPart
                end
            elseif mode == 4 then
                if hp > 0 and (bestVal == nil or hp < bestVal) then
                    bestVal = hp; best = rootPart
                end
            end
        end
    end

    return best
end

-- ── Fire loop ─────────────────────────────────────────────────────────────────
local function syncAllGatlings(target)
    for _, tr in pairs(trackedGatlings) do
        for _ = 1, getgenv().multiplytimes do
            pcall(function()
                GatlingChannel:Fire(target)
            end)
        end
    end
end

task.spawn(function()
    while true do
        task.wait(getgenv().gatlingcooldown)
        if getgenv().auto_fire then
            local target = getTarget()
            if target then
                syncAllGatlings(target)
            end
        end
    end
end)

