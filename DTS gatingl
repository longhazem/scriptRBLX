_G.Config = {
    gatlingcooldown = 0.01,
    multiplytimes   = 50,
    norecoil        = true,
    auto_fire       = true,   -- bật mặc định
    enabled         = true,
    aimRadius       = 300,
    maxRange        = 500
}

local Network       = game.ReplicatedStorage:WaitForChild("Network", 8)
local GatlingNetwork = Network and Network:WaitForChild("GatlingGun", 8)
local RE_Fire       = GatlingNetwork and GatlingNetwork:WaitForChild("RE:Fire", 8)

if not RE_Fire then return end

local uis     = game:GetService("UserInputService")
local Players = game:GetService("Players")
local camera  = workspace.CurrentCamera
local player  = Players.LocalPlayer
local npcs    = workspace:WaitForChild("NPCs")

local function getEnemyRoot(model)
    return model:FindFirstChild("HumanoidRootPart")
        or model:FindFirstChild("Hitbox")
        or model.PrimaryPart
        or model:FindFirstChildWhichIsA("BasePart")
end

local function getEnemies()
    local list = {}
    for _, model in ipairs(npcs:GetChildren()) do
        if model:IsA("Model") then
            local rp = model:FindFirstChild("RootPointer")
            if rp and rp.Value then
                local folder   = rp.Value
                local fakeUnit = folder:GetAttribute("FakeUnit")
                local unitType = folder:GetAttribute("Type")
                if fakeUnit == false and unitType == "Enemies" then
                    local root = getEnemyRoot(model)
                    local hp   = folder:GetAttribute("Health") or 0
                    if root and hp > 0 then
                        table.insert(list, { model = model, root = root, hp = hp })
                    end
                end
            end
        end
    end
    return list
end

local function getAimTarget()
    local viewportSize = camera.ViewportSize
    local screenCenter = Vector2.new(viewportSize.X / 2, viewportSize.Y / 2)
    local enemies      = getEnemies()
    if #enemies == 0 then return nil end

    local bestEnemy  = nil
    local bestDist2D = math.huge

    for _, e in ipairs(enemies) do
        local screenPos, onScreen = camera:WorldToViewportPoint(e.root.Position)
        if onScreen then
            local dist2D = (Vector2.new(screenPos.X, screenPos.Y) - screenCenter).Magnitude
            if dist2D < _G.Config.aimRadius and dist2D < bestDist2D then
                local dist3D = (e.root.Position - camera.CFrame.Position).Magnitude
                if dist3D <= _G.Config.maxRange then
                    bestDist2D = dist2D
                    bestEnemy  = e
                end
            end
        end
    end

    return bestEnemy
end

local function getFallbackPosition()
    local viewportSize = camera.ViewportSize
    local screenCenter = Vector2.new(viewportSize.X / 2, viewportSize.Y / 2)
    local ray          = camera:ViewportPointToRay(screenCenter.X, screenCenter.Y, 0)

    local rayParams = RaycastParams.new()
    rayParams.FilterType = Enum.RaycastFilterType.Exclude
    local ignore = {}
    if player.Character then table.insert(ignore, player.Character) end
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Character then table.insert(ignore, p.Character) end
    end
    local towers = workspace:FindFirstChild("Towers")
    if towers then table.insert(ignore, towers) end
    rayParams.FilterDescendantsInstances = ignore

    local result = workspace:Raycast(ray.Origin, ray.Direction * _G.Config.maxRange, rayParams)
    return result and result.Position or (ray.Origin + ray.Direction * _G.Config.maxRange)
end

local function sendFirePacket()
    if not _G.Config.enabled then return end

    local enemy     = getAimTarget()
    local targetPos

    if enemy then
        local vel     = enemy.root.AssemblyLinearVelocity
        local predicted = enemy.root.Position + vel * 0.05
        targetPos     = Vector3.new(predicted.X, predicted.Y, predicted.Z)
    else
        targetPos = getFallbackPosition()
    end

    local sync       = workspace:GetAttribute("Sync") or 0
    local serverTime = workspace:GetServerTimeNow()

    for i = 1, _G.Config.multiplytimes do
        pcall(function()
            RE_Fire:FireServer(
                vector.create(targetPos.X, targetPos.Y, targetPos.Z),
                sync,
                serverTime + (i * 0.0005)
            )
        end)
    end
end

-- ── Manual click fire ────────────────────────────────────────────────────────
local manualFiring = false

uis.InputBegan:Connect(function(input, gp)
    if gp or not _G.Config.enabled then return end
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        manualFiring = true
        task.spawn(function()
            while manualFiring and uis:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) do
                sendFirePacket()
                task.wait(_G.Config.gatlingcooldown)
            end
            manualFiring = false
        end)
    end
end)

uis.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        manualFiring = false
    end
end)

-- ── Auto fire — chạy độc lập, không bị manualFiring chặn ────────────────────
task.spawn(function()
    while true do
        task.wait(_G.Config.gatlingcooldown)
        if _G.Config.enabled and _G.Config.auto_fire then
            sendFirePacket()
        end
    end
end)

-- ── Config updater ────────────────────────────────────────────────────────────
_G.UpdateGatling = function(newConfig)
    for k, v in pairs(newConfig) do
        if _G.Config[k] ~= nil then
            _G.Config[k] = v
        end
    end
    print(string.format(
        "[TokaiHub] Config updated — Multiply: %d | Cooldown: %.3f | AimRadius: %d | AutoFire: %s",
        _G.Config.multiplytimes,
        _G.Config.gatlingcooldown,
        _G.Config.aimRadius,
        tostring(_G.Config.auto_fire)
    ))
end

print("[TokaiHub] Gatling loaded. AutoFire:", _G.Config.auto_fire)
