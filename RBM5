local repo = "https://raw.githubusercontent.com/deividcomsono/Obsidian/main/"

local Library, ThemeManager, SaveManager
do
	local function httpGet(url)
		-- Try 1: standard HttpGet (Delta, Synapse Z, Wave, Codex, Xeno)
		local ok, r = pcall(function() return game:HttpGet(url, true) end)
		if ok and type(r) == "string" and #r > 100 then return r end

		-- Try 2: no second arg (Volt, some Potassium builds)
		local ok2, r2 = pcall(function() return game:HttpGet(url) end)
		if ok2 and type(r2) == "string" and #r2 > 100 then return r2 end

		-- Try 3: HttpGetAsync (older Synapse, OpiumWare)
		local ok3, r3 = pcall(function() return game:HttpGetAsync(url) end)
		if ok3 and type(r3) == "string" and #r3 > 100 then return r3 end

		-- Try 4: syn.request (Fluxus, Arceus X mobile, Hydrogen)
		if syn and syn.request then
			local ok4, r4 = pcall(function()
				local res = syn.request({ Url = url, Method = "GET" })
				return res and res.Body
			end)
			if ok4 and type(r4) == "string" and #r4 > 100 then return r4 end
		end

		-- Try 5: http.request (some mobile executors)
		if http and http.request then
			local ok5, r5 = pcall(function()
				local res = http.request({ Url = url, Method = "GET" })
				return res and res.Body
			end)
			if ok5 and type(r5) == "string" and #r5 > 100 then return r5 end
		end

		warn("[Tokai Hub] httpGet failed for: " .. tostring(url))
		return nil
	end

	local src = httpGet(repo .. "Library.lua")
	if src then
		local ok, lib = pcall(loadstring(src))
		if ok then Library = lib end
	end

	if Library then
		local ts = httpGet(repo .. "addons/ThemeManager.lua")
		if ts then pcall(function() ThemeManager = loadstring(ts)() end) end
		local ss = httpGet(repo .. "addons/SaveManager.lua")
		if ss then pcall(function() SaveManager = loadstring(ss)() end) end
	end

	if not Library then
		warn("[Tokai Hub] Obsidian failed to load.")
		-- Headless stub — logic still runs, no crash
		local function _noop() end
		local function _stubGB()
			return {
				AddToggle   = _noop, AddSlider = _noop,
				AddDropdown = _noop, AddButton = _noop,
				AddLabel    = _noop, AddInput  = _noop,
				AddColorPicker = _noop, AddKeybind = _noop,
			}
		end
		local function _stubTab()
			return {
				AddLeftGroupbox  = function() return _stubGB() end,
				AddRightGroupbox = function() return _stubGB() end,
			}
		end
		Library = {
			CreateWindow = function() return {
				AddTab = function() return _stubTab() end,
			} end,
			Options  = {}, Toggles = {},
			Notify   = _noop,
			ShowGui  = _noop,
		}
		ThemeManager = { SetLibrary=_noop, SetFolder=_noop, ApplyToWindow=_noop }
		SaveManager  = { SetLibrary=_noop, SetFolder=_noop, BuildConfigSection=_noop, LoadAutoloadConfig=_noop }
	end
end

