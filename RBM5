                local r1 = math.rad(camAngleY)
                local r2 = math.rad(camAngleX)
                local d = 5
                vpCam.CFrame = CFrame.new(
                    center + Vector3.new(
                        math.sin(r1)*math.cos(r2)*d,
                        math.sin(r2)*d,
                        math.cos(r1)*math.cos(r2)*d
                    ), center
                )
