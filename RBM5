            TweenService:Create(row, TweenInfo.new(0.1), {BackgroundColor3=flashCol}):Play()
            task.delay(0.2, function()
                TweenService:Create(row, TweenInfo.new(0.25), {BackgroundColor3=Color3.fromRGB(255,255,255)}):Play()
            end)
            -- Pulse glow nếu bật
