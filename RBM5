if not filtergc then
	filtergc = function(typeFilter)
		-- getgc(true) may fail on some executors — try both arg forms
		local gc
		local ok, r1 = pcall(function() return getgc(true) end)
		if ok and type(r1) == "table" and #r1 > 0 then
			gc = r1
		else
			local ok2, r2 = pcall(function() return getgc() end)
			if ok2 and type(r2) == "table" then gc = r2 end
		end
		if not gc then return {} end
		if not typeFilter then return gc end
		local result = {}
		for _, v in pairs(gc) do
			if type(v) == typeFilter then result[#result+1] = v end
		end
		return result
	end
end
if not getgc then
	if debug and debug.getregistry then
		getgc = function(inc)
			local ok, reg = pcall(function() return debug.getregistry() end)
			if not ok or type(reg) ~= "table" then return {} end
			local out = {}
			for _, v in pairs(reg) do
				if inc or type(v) == "function" then out[#out+1] = v end
			end
			return out
		end
	else
		getgc = function() return {} end
		warn("[Tokai Hub] getgc unavailable — BulkScan disabled.")
	end
end
