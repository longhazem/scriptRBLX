local function isVisible(targetPos)
    if not config.wallcheck then return true end
    local origin = camera.CFrame.Position
    local dir = targetPos - origin
    local raycastParams = RaycastParams.new()
    raycastParams.FilterDescendantsInstances = {lp.Character, camera}
    raycastParams.FilterType = Enum.RaycastFilterType.Exclude
    local result = pcall(function()
        return Workspace:Raycast(origin, dir, raycastParams)
    end)
    
    if result then
        local hitInstance = result.Instance
        if hitInstance and hitInstance:IsDescendantOf(workspace:FindFirstChild("Game")) then
            return true
        end
        return false
    end
    return true
end

local function getClosestHead()
    local container = getEnemyContainer()
    if not container then return nil end

    local referencePos
    if isMobile then
        local vp = camera.ViewportSize
        referencePos = Vector2.new(vp.X / 2, vp.Y / 2)
    else
        referencePos = UserInputService:GetMouseLocation()
    end

    local bestZombie = nil
    local bestDist = math.huge
    local criticalParts = {"Head", "HumanoidRootPart", "Torso"}

    for _, enemy in ipairs(container:GetChildren()) do
        if not enemy:IsA("Model") or not enemy:FindFirstChild("Humanoid") then continue end
        local hum = enemy:FindFirstChild("Humanoid")
        if hum and hum.Health <= 0 then continue end

        local headPart = enemy:FindFirstChild("Head") or enemy:FindFirstChild("head")
        if not headPart then
            headPart = enemy:FindFirstChild("HumanoidRootPart") or enemy:FindFirstChild("Torso")
        end
        if not headPart then continue end

        local found = false
        local minDist = math.huge
        for _, partName in ipairs(criticalParts) do
            local part = enemy:FindFirstChild(partName)
            if part and part:IsA("BasePart") then
                local screenPoint, onScreen = camera:WorldToScreenPoint(part.Position)
                if onScreen then
                    local dist = (Vector2.new(screenPoint.X, screenPoint.Y) - referencePos).Magnitude
                    if dist <= config.fovSize and dist <= config.aimbotRange then
                        if dist < minDist then minDist = dist end
                        found = true
                    end
                end
            end
        end

        if found and minDist < bestDist then
            if config.wallcheck and not isVisible(headPart.Position) then
                continue
            end
            bestDist = minDist
            bestZombie = enemy
        end
    end

    if bestZombie then
        local head = bestZombie:FindFirstChild("Head") or bestZombie:FindFirstChild("head")
        if head then return head.Position end
        local root = bestZombie:FindFirstChild("HumanoidRootPart") or bestZombie:FindFirstChild("Torso")
        if root then return root.Position end
    end
    return nil
end

