-- ====== ESP ======
local function UpdateVisuals(obj, shouldShow, color, nameText)
    if not obj or not obj.Parent then return end
    pcall(function()
        if shouldShow then
            if not obj:FindFirstChild("TokaiHighlight") then
                local h = Instance.new("Highlight")
                h.Name = "TokaiHighlight"
                h.FillColor = color
                h.OutlineColor = color
                h.FillTransparency = 0.3
                h.OutlineTransparency = 0
                h.Parent = obj
                highlightObjects[obj] = true
            end
            
            if config.nameESP then
                local label = obj:FindFirstChild("TokaiNameESP")
                if not label then
                    label = Instance.new("BillboardGui")
                    label.Name = "TokaiNameESP"
                    label.Size = UDim2.new(0, 200, 0, 50)
                    label.StudsOffset = Vector3.new(0, 3, 0)
                    label.AlwaysOnTop = true
                    local tl = Instance.new("TextLabel")
                    tl.Parent = label
                    tl.Size = UDim2.new(1, 0, 1, 0)
                    tl.BackgroundTransparency = 1
                    tl.Text = nameText
                    tl.TextColor3 = color
                    tl.TextStrokeTransparency = 0
                    tl.TextSize = 13
                    label.Parent = obj
                end
            end
        else
            local h = obj:FindFirstChild("TokaiHighlight")
            if h then h:Destroy() end
            local l = obj:FindFirstChild("TokaiNameESP")
            if l then l:Destroy() end
            highlightObjects[obj] = nil
        end
    end)
end

local function UpdateESP()
    pcall(function()
        local gw = workspace:FindFirstChild("Game")
        if not gw then return end
        local c = gw:FindFirstChild("Current")
        if not c then return end
        local s = c:FindFirstChild("Spawned")
        if not s then return end
        
        local go = s:FindFirstChild("GameObjects")
        if go then
            for _, obj in ipairs(go:GetChildren()) do
                if obj and obj.Parent then
                    local n = obj.Name
                    if n:find("mission_") or n == "scenery_phone_ringing" then
                        UpdateVisuals(obj, config.objectiveESP, Color3.fromRGB(0, 255, 0), "Objective")
                    elseif n == "pickup_ammo" then
                        UpdateVisuals(obj, config.ammoESP, Color3.fromRGB(255, 255, 0), "Ammo")
                    elseif n == "pickup_armor" then
                        UpdateVisuals(obj, config.armorESP, Color3.fromRGB(0, 0, 255), "Armor")
                    elseif n == "pickup_medkit" then
                        UpdateVisuals(obj, config.medkitESP, Color3.fromRGB(255, 0, 0), "Medkit")
                    end
                end
            end
        end
        
        local npcs = s:FindFirstChild("NPCs")
        if npcs then
            local enemies = npcs:FindFirstChild("enemies")
            if enemies then
                for _, z in ipairs(enemies:GetChildren()) do
                    if z:IsA("Model") and z:FindFirstChild("Humanoid") then
                        UpdateVisuals(z, config.zombieESP, Color3.fromRGB(255, 0, 0), "Zombie")
                    end
                end
            end
        end
    end)
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= lp and player.Character then
            UpdateVisuals(player.Character, config.playerESP, Color3.fromRGB(0, 255, 255), player.Name)
        end
    end
end

-- ====== HELPERS ======
local function getEnemyContainer()
    local c = workspace:FindFirstChild("Game")
    if c then c = c:FindFirstChild("Current") end
    if c then c = c:FindFirstChild("Spawned") end
    if c then c = c:FindFirstChild("NPCs") end
    if c then return c:FindFirstChild("enemies") end
    return nil
end

local function isPlayerCharacter(m) return m and m:IsA("Model") and Players:GetPlayerFromCharacter(m) ~= nil end
local function isHumanoidModel(m) return m and m:IsA("Model") and m:FindFirstChildWhichIsA("Humanoid") ~= nil end

-- ====== HITBOX ======
function applyHitboxExpander(part)
    if not part or not part:IsA("BasePart") or string.lower(part.Name) ~= "head" then return end
    local m = part.Parent
    if not isHumanoidModel(m) or isPlayerCharacter(m) or not config.hitboxExpander then return end
    local h = m:FindFirstChild("Humanoid")
    if not h or h.Health <= 0 then return end
    pcall(function()
        if not expandedHitboxes[part] then
            originalSizes[part] = part.Size
            expandedHitboxes[part] = true
        end
        part.Size = Vector3.new(config.hitboxSize, config.hitboxSize, config.hitboxSize)
        part.CanCollide = false
        part.Transparency = 0.7
    end)
end

function revertHitboxExpander(part)
    if not part or not part:IsA("BasePart") then return end
    pcall(function()
        if originalSizes[part] then
            part.Size = originalSizes[part]
            originalSizes[part] = nil
        else
            part.Size = Vector3.new(1, 1, 1)
        end
        part.Transparency = 0
        part.CanCollide = true
        expandedHitboxes[part] = nil
    end)
end

function applyToAllZombies()
    if not config.hitboxExpander then return end
    local c = getEnemyContainer()
    if not c then return end
    for _, enemy in ipairs(c:GetChildren()) do
        if enemy:IsA("Model") and enemy:FindFirstChild("Humanoid") then
            local h = enemy:FindFirstChild("Head") or enemy:FindFirstChild("head")
            if h then applyHitboxExpander(h) end
        end
    end
end

function revertAllHitboxes()
    for part, _ in pairs(expandedHitboxes) do
        if part and part.Parent then revertHitboxExpander(part) end
    end
    expandedHitboxes = {}
    originalSizes = {}
end

function toggleHitboxExpander(status)
    config.hitboxExpander = status
    if status then applyToAllZombies() else revertAllHitboxes() end
end

local function hookZombie(model)
    if not model:IsA("Model") or not model:FindFirstChild("Humanoid") or isPlayerCharacter(model) then return end
    local h = model:FindFirstChild("Humanoid")
    if h then
        h.HealthChanged:Connect(function()
            if h.Health <= 0 then
                for part, _ in pairs(expandedHitboxes) do
                    if part and part:IsDescendantOf(model) then
                        revertHitboxExpander(part)
                        expandedHitboxes[part] = nil
                        originalSizes[part] = nil
                    end
                end
            elseif config.hitboxExpander then
                local head = model:FindFirstChild("Head") or model:FindFirstChild("head")
                if head then applyHitboxExpander(head) end
            end
        end)
        if h.Health > 0 and config.hitboxExpander then
            local head = model:FindFirstChild("Head") or model:FindFirstChild("head")
            if head then applyHitboxExpander(head) end
        end
    end
end

Workspace.DescendantAdded:Connect(function(d)
    if d:IsA("Model") and d:FindFirstChild("Humanoid") and not isPlayerCharacter(d) then
