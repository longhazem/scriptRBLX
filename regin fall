-- WEAPON MODIFICATIONS (NORECOIL + RPM)
-- ═════════════════════════════════════════════════════════════════════════════

local function ModifyWeaponRecoil(tool)
    if not tool then return end
    pcall(function()
        local weaponData = tool:FindFirstChild("WeaponData")
        if not weaponData then return end
        
        if config.norecoil then
            local recoil = weaponData:FindFirstChild("Recoil")
            if recoil then
                recoil.Value = 0
            end
            
            local cameraKick = weaponData:FindFirstChild("CameraKick")
            if cameraKick then
                cameraKick.Value = 0
            end
        end
        
        if config.rpm > 0 then
            local fireRate = weaponData:FindFirstChild("FireRate")
            if fireRate then
                fireRate.Value = 60 / config.rpm
            end
        end
    end)
end

local function ModifyAllWeapons()
    local backpack = lp:FindFirstChild("Backpack")
    if backpack then
        for _, tool in ipairs(backpack:GetChildren()) do
            if tool:IsA("Tool") then
                ModifyWeaponRecoil(tool)
            end
        end
    end
    local character = lp.Character
    if character then
        for _, tool in ipairs(character:GetChildren()) do
            if tool:IsA("Tool") then
                ModifyWeaponRecoil(tool)
            end
        end
    end
end

lp.CharacterAdded:Connect(function()
    task.wait(0.5)
    if config.norecoil or config.rpm > 0 then
        ModifyAllWeapons()
    end
end)

RunService.Heartbeat:Connect(function()
    if config.norecoil or config.rpm > 0 then
        ModifyAllWeapons()
    end
end)

