local function AddHighlight(obj, color, transparency)
   if not obj or not obj.Parent then return end
   pcall(function()
      if obj:FindFirstChild("TokaiHighlight") then
         obj:FindFirstChild("TokaiHighlight"):Destroy()
      end
      local highlight = Instance.new("Highlight")
      highlight.Name = "TokaiHighlight"
      highlight.FillColor = color
      highlight.OutlineColor = color
      highlight.FillTransparency = transparency or 0.3
      highlight.OutlineTransparency = 0
      highlight.Parent = obj
      highlightObjects[obj] = true
   end)
end

local function RemoveHighlight(obj)
   pcall(function()
      local highlight = obj:FindFirstChild("TokaiHighlight")
      if highlight then
         highlight:Destroy()
         highlightObjects[obj] = nil
      end
   end)
end

local function UpdateObjectiveESP()
   for obj, _ in pairs(highlightObjects) do
      if obj and obj.Parent then
         local name = obj.Name
         if (name:sub(1, 8) == "mission_" or name == "scenery_phone_ringing") and not config.objectiveESP then
            RemoveHighlight(obj)
         elseif name == "pickup_ammo" and not config.ammoESP then
            RemoveHighlight(obj)
         elseif name == "pickup_armor" and not config.armorESP then
            RemoveHighlight(obj)
         elseif name == "pickup_medkit" and not config.medkitESP then
            RemoveHighlight(obj)
         end
      end
   end

   local game_workspace = workspace:FindFirstChild("Game")
   if not game_workspace then return end
   local current = game_workspace:FindFirstChild("Current")
   if not current then return end
   local spawned = current:FindFirstChild("Spawned")
   if not spawned then return end
   local gameObjects = spawned:FindFirstChild("GameObjects")
   if not gameObjects then return end
   
   for _, obj in ipairs(gameObjects:GetChildren()) do
      local name = obj.Name
      local isMission = name:sub(1, 8) == "mission_"
      local isPhone = name == "scenery_phone_ringing"
      local isAmmo = name == "pickup_ammo"
      local isArmor = name == "pickup_armor"
      local isMedkit = name == "pickup_medkit"
      
      if isMission or isPhone or isAmmo or isArmor or isMedkit then
         local shouldHighlight = false
         local color = nil
         
         if (isMission or isPhone) and config.objectiveESP then
            shouldHighlight = true
            if isMission then
               color = Color3.fromRGB(0, 255, 0)
            else
               color = Color3.fromRGB(255, 255, 255)
            end
         elseif isAmmo and config.ammoESP then
            shouldHighlight = true
            color = Color3.fromRGB(255, 255, 0)
         elseif isArmor and config.armorESP then
            shouldHighlight = true
            color = Color3.fromRGB(0, 0, 255)
         elseif isMedkit and config.medkitESP then
            shouldHighlight = true
            color = Color3.fromRGB(255, 0, 0)
         end
         
         if shouldHighlight then
            if not obj:FindFirstChild("TokaiHighlight") then
               AddHighlight(obj, color, 0.3)
            end
         end
      end
   end
end

local function UpdatePlayerESP()
   if not config.playerESP then
      for obj, _ in pairs(highlightObjects) do
         if obj and obj.Parent and obj:FindFirstChild("Humanoid") then
            RemoveHighlight(obj)
         end
      end
      return
   end
   local npcContainer = workspace.Game and workspace.Game.Current and workspace.Game.Current.Spawned and workspace.Game.Current.Spawned.NPCs
   if npcContainer then
      local enemiesFolder = npcContainer:FindFirstChild("enemies")
      if enemiesFolder then
         for _, zombie in ipairs(enemiesFolder:GetChildren()) do
            if zombie:IsA("Model") and zombie:FindFirstChild("Humanoid") then
               if not zombie:FindFirstChild("TokaiHighlight") then
                  AddHighlight(zombie, Color3.fromRGB(255, 0, 0), 0.3)
               end
            end
         end
      end
   end
   for _, player in ipairs(Players:GetPlayers()) do
      if player ~= lp and player.Character then
         local char = player.Character
         if char and char:FindFirstChild("Humanoid") then
            if not char:FindFirstChild("TokaiHighlight") then
               AddHighlight(char, Color3.fromRGB(0, 255, 255), 0.3)
            end
         end
      end
   end
end

local function UpdateHitboxExpander()
   local currentHeads = {}
   
   if config.hitboxExpander then
      local npcContainer = workspace.Game and workspace.Game.Current and workspace.Game.Current.Spawned and workspace.Game.Current.Spawned.NPCs
      if npcContainer then
         local enemiesFolder = npcContainer:FindFirstChild("enemies")
         if enemiesFolder then
            for _, zombie in ipairs(enemiesFolder:GetChildren()) do
               if zombie:IsA("Model") then
                  local hum = zombie:FindFirstChild("Humanoid")
                  local head = zombie:FindFirstChild("Head")
                  if hum and hum.Health > 0 and head then
                     currentHeads[head] = true
                     if not expandedHitboxes[head] then
                        expandedHitboxes[head] = head.Size
                        head.Size = Vector3.new(config.hitboxSize, config.hitboxSize, config.hitboxSize)
                        head.CanCollide = false
                        head.Transparency = 0.7
                     else
                        head.Size = Vector3.new(config.hitboxSize, config.hitboxSize, config.hitboxSize)
                     end
                  end
               end
            end
         end
      end
      
      for _, player in ipairs(Players:GetPlayers()) do
         if player ~= lp and player.Character then
            local char = player.Character
            local hum = char:FindFirstChild("Humanoid")
            local head = char:FindFirstChild("Head")
            if hum and hum.Health > 0 and head then
               currentHeads[head] = true
               if not expandedHitboxes[head] then
                  expandedHitboxes[head] = head.Size
                  head.Size = Vector3.new(config.hitboxSize, config.hitboxSize, config.hitboxSize)
                  head.CanCollide = false
                  head.Transparency = 0.7
               else
                  head.Size = Vector3.new(config.hitboxSize, config.hitboxSize, config.hitboxSize)
               end
            end
         end
      end
   end
   
   for part, origSize in pairs(expandedHitboxes) do
      if not currentHeads[part] then
         if part and part.Parent then
            pcall(function()
               part.Size = origSize or Vector3.new(1, 1, 1)
               part.Transparency = 0
            end)
         end
         expandedHitboxes[part] = nil
      end
   end
end

local function getEnemyContainer()
   local container = workspace.Game and workspace.Game.Current and workspace.Game.Current.Spawned and workspace.Game.Current.Spawned.NPCs
   if container then
      return container:FindFirstChild("enemies")
   end
   return nil
end

local function isVisible(targetPart)
   local origin = camera.CFrame.Position
   local direction = targetPart.Position - origin
   local rayParams = RaycastParams.new()
   rayParams.FilterDescendantsInstances = {lp.Character, camera}
   rayParams.FilterType = Enum.RaycastFilterType.Exclude
   rayParams.IgnoreWater = true
   
   local result = Workspace:Raycast(origin, direction, rayParams)
   if result then
      if result.Instance:IsDescendantOf(targetPart.Parent) then
         return true
      end
      return false
   end
   return true
end

local function getClosestHead()
   local container = getEnemyContainer()
   if not container then return nil end
   local referencePos
   if isMobile then
      local vp = camera.ViewportSize
      referencePos = Vector2.new(vp.X / 2, vp.Y / 2)
   else
      referencePos = UserInputService:GetMouseLocation()
   end
   local bestHeadPos = nil
   local bestDist = config.aimbotFov
   for _, enemy in ipairs(container:GetChildren()) do
      local head = enemy:FindFirstChild("Head") or enemy:FindFirstChild("HumanoidRootPart")
      local hum = enemy:FindFirstChild("Humanoid")
      if head and hum and hum.Health > 0 then
         local screenPoint, onScreen = camera:WorldToScreenPoint(head.Position)
         if onScreen then
            local dist = (Vector2.new(screenPoint.X, screenPoint.Y) - referencePos).Magnitude
            if dist < bestDist then
               if not config.wallCheck or isVisible(head) then
                  bestDist = dist
                  bestHeadPos = head.Position
               end
            end
         end
      end
   end
   return bestHeadPos
end

RunService.Heartbeat:Connect(function()
   if (config.raycasting or config.aimbot) and target.enabled then
      target.position = getClosestHead()
   end
   
   if config.aimbot and target.position then
      camera.CFrame = CFrame.new(camera.CFrame.Position, target.position)
   end
   
   if config.rainbowGun then
      local c = tick() % 5 / 5
      local d = Color3.fromHSV(c, 1, 1)
      local viewmodel = camera:FindFirstChild("Viewmodel") or camera:FindFirstChild("ViewModel")
      if viewmodel then
         for _, f in pairs(viewmodel:GetDescendants()) do
            if f:IsA("BasePart") or f:IsA("MeshPart") then
               f.Material = Enum.Material.ForceField
               f.Color = d
               f.Transparency = 0.3
            end
         end
      end
   end
end)

local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
   local method = getnamecallmethod()
   local args = {...}
   
   if config.raycasting and target.enabled and method:lower() == "raycast" and self == Workspace then
      if #args >= 2 and typeof(args[1]) == "Vector3" and typeof(args[2]) == "Vector3" then
         local raycastParams = args[3]
         if raycastParams and raycastParams.CollisionGroup == "raycast_npc_neutral" then
            if target.position then
               local origin = args[1]
               local dir = target.position - origin
               if dir.Magnitude > 0.001 then
                  args[2] = dir.Unit * args[2].Magnitude
               end
            end
         end
      end
      return oldNamecall(self, unpack(args))
   end
   return oldNamecall(self, unpack(args))
end))

local function findRegisterHitEvent()
   local v3 = lp.Character
   if not v3 then return nil end
   for v2, v4 in ipairs(v3:GetChildren()) do
      local v9 = v4:FindFirstChild("ServerEvents")
      if v9 then
         local v8 = v9:FindFirstChild("RegisterHit")
         if v8 and v8:IsA("RemoteEvent") then
            return v8
         end
      end
   end
   return nil
end

local function getAutoHitTargets()
   local v11 = {}
   for v2, v7 in ipairs(Workspace:GetDescendants()) do
      if v7:IsA("Model") and v7:FindFirstChild("Humanoid") and v7 ~= lp.Character then
         local hum = v7:FindFirstChild("Humanoid")
         local v12 = v7:FindFirstChild("Torso") or v7:FindFirstChild("HumanoidRootPart")
         if v12 and hum and hum.Health > 0 then
            table.insert(v11, {model = v7, part = v12})
         end
      end
   end
   return v11
end

task.spawn(function()
   while task.wait(0.2) do
      if config.autoHit then
         local v5 = findRegisterHitEvent()
         if v5 then
            local v11 = getAutoHitTargets()
            if #v11 > 0 then
               local v6 = {}
               for v2, v10 in ipairs(v11) do
                  table.insert(v6, {amount = 1, target = v10.model, is_friendly = false, part = v10.part})
               end
               if #v6 > 0 then
                  v5:FireServer(v6, {})
               end
            end
         end
      end
   end
end)

task.spawn(function()
   while task.wait(0.1) do
      local Character = lp.Character
      if Character then
         if config.infiniteStamina then
            local Humanoid = Character:FindFirstChild("Humanoid")
            if Humanoid then
               local Values = Humanoid:FindFirstChild("Values")
               if Values then
                  local Stamina = Values:FindFirstChild("Stamina")
                  if Stamina and Stamina:IsA("NumberValue") then
                     Stamina.Value = math.huge
                  end
               end
            end
         end
         
         if config.infiniteAmmo then
            local Backpack = lp:FindFirstChild("Backpack")
            local items = {}
            
            for _, v in ipairs(Character:GetChildren()) do
               table.insert(items, v)
            end
            
            if Backpack then
               for _, v in ipairs(Backpack:GetChildren()) do
                  table.insert(items, v)
               end
            end
            
            for _, item in ipairs(items) do
               if item:IsA("Tool") then
                  local WeaponData = item:FindFirstChild("WeaponData")
                  if WeaponData then
                     local Essentials = WeaponData:FindFirstChild("Essentials")
                     if Essentials then
                        local Ammo = Essentials:FindFirstChild("Ammo")
                        if Ammo and Ammo:IsA("NumberValue") then
                           Ammo.Value = math.huge
                        end
                     end
                  end
               end
            end
         end
      end
   end
end)

