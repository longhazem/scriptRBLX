local function UpdateVisuals(obj, shouldShow, color, nameText)
    if not obj or not obj.Parent then return end
    pcall(function()
        if shouldShow then
            if not obj:FindFirstChild("TokaiHighlight") then
                local highlight = Instance.new("Highlight")
                highlight.Name = "TokaiHighlight"
                highlight.FillColor = color
                highlight.OutlineColor = color
                highlight.FillTransparency = 0.3
                highlight.OutlineTransparency = 0
                highlight.Parent = obj
                highlightObjects[obj] = true
            end
            local label = obj:FindFirstChild("TokaiNameESP")
            if config.nameESP then
                if not label then
                    label = Instance.new("BillboardGui")
                    label.Name = "TokaiNameESP"
                    label.Size = UDim2.new(0, 200, 0, 50)
                    label.StudsOffset = Vector3.new(0, 3, 0)
                    label.AlwaysOnTop = true
                    local textLabel = Instance.new("TextLabel")
                    textLabel.Parent = label
                    textLabel.Size = UDim2.new(1, 0, 1, 0)
                    textLabel.BackgroundTransparency = 1
                    textLabel.Text = nameText
                    textLabel.TextColor3 = color
                    textLabel.TextStrokeTransparency = 0
                    textLabel.TextSize = 13
                    label.Parent = obj
                else
                    label.TextLabel.Text = nameText
                    label.TextLabel.TextColor3 = color
                end
            else
                if label then label:Destroy() end
            end
        else
            local highlight = obj:FindFirstChild("TokaiHighlight")
            if highlight then highlight:Destroy() end
            local label = obj:FindFirstChild("TokaiNameESP")
            if label then label:Destroy() end
            highlightObjects[obj] = nil
        end
    end)
end

local function UpdateESP()
    pcall(function()
        local game_workspace = workspace:FindFirstChild("Game")
        if not game_workspace then return end
        
        local current = game_workspace:FindFirstChild("Current")
        if not current then return end
        
        local spawned = current:FindFirstChild("Spawned")
        if not spawned then return end
        
        local gameObjects = spawned:FindFirstChild("GameObjects")
        if gameObjects then
            for _, obj in ipairs(gameObjects:GetChildren()) do
                if not obj or not obj.Parent then continue end
                local name = obj.Name
                if name:sub(1, 8) == "mission_" or name == "scenery_phone_ringing" then
                    local color = name:sub(1, 8) == "mission_" and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 255, 255)
                    UpdateVisuals(obj, config.objectiveESP, color, "Objective")
                elseif name == "pickup_ammo" then
                    UpdateVisuals(obj, config.ammoESP, Color3.fromRGB(255, 255, 0), "Ammo")
                elseif name == "pickup_armor" then
                    UpdateVisuals(obj, config.armorESP, Color3.fromRGB(0, 0, 255), "Armor")
                elseif name == "pickup_medkit" then
                    UpdateVisuals(obj, config.medkitESP, Color3.fromRGB(255, 0, 0), "Medkit")
                end
            end
        end
        
        local npcs = spawned:FindFirstChild("NPCs")
        if npcs and npcs:FindFirstChild("enemies") then
            for _, zombie in ipairs(npcs.enemies:GetChildren()) do
                if zombie:IsA("Model") and zombie:FindFirstChild("Humanoid") then
                    UpdateVisuals(zombie, config.zombieESP, Color3.fromRGB(255, 0, 0), "Zombie")
                end
            end
        end
    end)
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= lp and player.Character and player.Character:FindFirstChild("Humanoid") then
            UpdateVisuals(player.Character, config.playerESP, Color3.fromRGB(0, 255, 255), player.Name)
        end
    end
end

