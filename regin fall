local function SetInfiniteAmmo(tool)
   if not tool then return end
   pcall(function()
      local ammo = tool:FindFirstChild("WeaponData", true) and tool:FindFirstChild("WeaponData", true):FindFirstChild("Essentials", true) and tool:FindFirstChild("WeaponData", true):FindFirstChild("Essentials", true):FindFirstChild("Ammo")
      if ammo then ammo.Value = 99999 end
   end)
end

RunService.Heartbeat:Connect(function()
   if config.infiniteAmmo then
      for _, tool in ipairs(lp.Backpack:GetChildren()) do if tool:IsA("Tool") then SetInfiniteAmmo(tool) end end
      if lp.Character then for _, tool in ipairs(lp.Character:GetChildren()) do if tool:IsA("Tool") then SetInfiniteAmmo(tool) end end end
   end
end)

