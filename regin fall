-- ====== AIMBOT ======
local function isVisible(targetPos)
    if not config.wallcheck then return true end
    local origin = camera.CFrame.Position
    local dir = targetPos - origin
    if dir.Magnitude == 0 then return true end
    
    local rp = RaycastParams.new()
    rp.FilterDescendantsInstances = {lp.Character}
    rp.FilterType = Enum.RaycastFilterType.Exclude
    
    local ok, result = pcall(function() return Workspace:Raycast(origin, dir, rp) end)
    if not ok or not result then return true end
    
    local hit = result.Instance
    return hit and (hit:IsDescendantOf(workspace:FindFirstChild("Game") or Instance.new("Folder")))
end

local function getClosestHead()
    local c = getEnemyContainer()
    if not c then return nil end
    
    local ref = isMobile and Vector2.new(camera.ViewportSize.X/2, camera.ViewportSize.Y/2) or UserInputService:GetMouseLocation()
    
    local best = nil
    local bestDist = math.huge
    
    for _, enemy in ipairs(c:GetChildren()) do
        if not enemy:IsA("Model") then continue end
        local h = enemy:FindFirstChild("Humanoid")
        if not h or h.Health <= 0 then continue end
        
        local head = enemy:FindFirstChild("Head") or enemy:FindFirstChild("HumanoidRootPart")
        if not head then continue end
        
        local sp, onScreen = camera:WorldToScreenPoint(head.Position)
        if onScreen then
            local d = (Vector2.new(sp.X, sp.Y) - ref).Magnitude
            if d <= config.fovSize and d < bestDist then
                if not config.wallcheck or isVisible(head.Position) then
                    bestDist = d
                    best = enemy
                end
            end
        end
    end
    
    if best then
        local h = best:FindFirstChild("Head") or best:FindFirstChild("HumanoidRootPart")
        return h and h.Position or nil
    end
    return nil
end

RunService.RenderStepped:Connect(function()
    if (config.raycasting or config.aimbot) and target.enabled then
        target.position = getClosestHead()
    end
end)

RunService.RenderStepped:Connect(function()
    if config.aimbot and target.position then
        pcall(function()
            camera.CFrame = CFrame.new(camera.CFrame.Position, target.position)
