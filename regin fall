local function getEnemyContainer()
    local container = workspace:FindFirstChild("Game")
    if not container then return nil end
    
    container = container:FindFirstChild("Current")
    if not container then return nil end
    
    container = container:FindFirstChild("Spawned")
    if not container then return nil end
    
    container = container:FindFirstChild("NPCs")
    if not container then return nil end
    
    return container:FindFirstChild("enemies")
end

local function isPlayerCharacter(model)
    if not model or not model:IsA("Model") then return false end
    return Players:GetPlayerFromCharacter(model) ~= nil
end

local function isHumanoidModel(model)
    if not model or not model:IsA("Model") then return false end
    return model:FindFirstChildWhichIsA("Humanoid") ~= nil
end

-- =================== HITBOX EXPANDER =====================
function applyHitboxExpander(part)
    if not part or not part:IsA("BasePart") then return end
    if string.lower(part.Name) ~= "head" then return end
    local model = part.Parent
    if not isHumanoidModel(model) or isPlayerCharacter(model) then return end
    if not config.hitboxExpander then return end

    local hum = model:FindFirstChild("Humanoid")
    if not hum or hum.Health <= 0 then return end

    pcall(function()
        if not expandedHitboxes[part] then
            originalSizes[part] = part.Size
            part.Size = Vector3.new(config.hitboxSize, config.hitboxSize, config.hitboxSize)
            part.CanCollide = false
            part.Transparency = 0.7
            expandedHitboxes[part] = true
        else
            part.Size = Vector3.new(config.hitboxSize, config.hitboxSize, config.hitboxSize)
            part.Transparency = 0.7
        end
    end)
end

function revertHitboxExpander(part)
    if not part or not part:IsA("BasePart") then return end
    pcall(function()
        if originalSizes[part] then
            part.Size = originalSizes[part]
            part.Transparency = 0
            part.CanCollide = true
            originalSizes[part] = nil
        else
            part.Size = Vector3.new(1, 1, 1)
            part.Transparency = 0
        end
        expandedHitboxes[part] = nil
    end)
end

function applyToAllZombies()
    if not config.hitboxExpander then return end
    local container = getEnemyContainer()
    if not container then return end
    for _, enemy in ipairs(container:GetChildren()) do
        if enemy:IsA("Model") and enemy:FindFirstChild("Humanoid") then
            local hum = enemy:FindFirstChild("Humanoid")
            if hum and hum.Health > 0 then
                local head = enemy:FindFirstChild("Head") or enemy:FindFirstChild("head")
                if head then applyHitboxExpander(head) end
            end
        end
    end
end

function revertAllHitboxes()
    for part, _ in pairs(expandedHitboxes) do
        if part and part.Parent then
            revertHitboxExpander(part)
        else
            expandedHitboxes[part] = nil
            originalSizes[part] = nil
        end
    end
    expandedHitboxes = {}
    originalSizes = {}
end

function toggleHitboxExpander(status)
    config.hitboxExpander = status
    if status then
        applyToAllZombies()
    else
        revertAllHitboxes()
    end
end

local function onHumanoidHealthChanged(model)
    local hum = model:FindFirstChild("Humanoid")
    if not hum then return end
    if hum.Health <= 0 then
        for part, _ in pairs(expandedHitboxes) do
            if part and part:IsDescendantOf(model) then
                revertHitboxExpander(part)
                expandedHitboxes[part] = nil
                originalSizes[part] = nil
            end
        end
    else
        if config.hitboxExpander then
            local head = model:FindFirstChild("Head") or model:FindFirstChild("head")
            if head then applyHitboxExpander(head) end
        end
    end
end

local function hookZombie(model)
    if not model:IsA("Model") then return end
    if not model:FindFirstChild("Humanoid") then return end
    if isPlayerCharacter(model) then return end
    local hum = model:FindFirstChild("Humanoid")
    if hum then
        hum.HealthChanged:Connect(function()
            onHumanoidHealthChanged(model)
        end)
        if hum.Health > 0 and config.hitboxExpander then
            local head = model:FindFirstChild("Head") or model:FindFirstChild("head")
            if head then applyHitboxExpander(head) end
        end
    end
end

