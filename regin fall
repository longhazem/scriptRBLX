    else
        FOVCircle.Visible = false
    end
    
    UpdateESP()
end)

local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
    local method = getnamecallmethod()
    if config.raycasting and target.enabled and method:lower() == "raycast" and self == Workspace then
        local args = {...}
        if #args >= 2 and typeof(args[1]) == "Vector3" and typeof(args[2]) == "Vector3" then
            local rp = args[3]
            if rp then
                local ok = pcall(function() return rp.CollisionGroup == "raycast_npc_neutral" end)
                if ok and rp.CollisionGroup == "raycast_npc_neutral" and target.position then
                    local dir = target.position - args[1]
                    if dir.Magnitude > 0.001 then
                        args[2] = dir.Unit * args[2].Magnitude
                    end
                end
            end
        end
        return oldNamecall(self, unpack(args))
    end
    return oldNamecall(self, ...)
end))

-- ====== AUTO HIT ======
local function findRegisterHitEvent()
    if not lp.Character then return nil end
    for _, v in ipairs(lp.Character:GetChildren()) do
        local se = v:FindFirstChild("ServerEvents")
        if se then
            local rh = se:FindFirstChild("RegisterHit")
            if rh and rh:IsA("RemoteEvent") then return rh end
        end
    end
    return nil
end

local function getTargets()
    local t = {}
    for _, v in ipairs(Workspace:GetDescendants()) do
        if v:IsA("Model") and v:FindFirstChild("Humanoid") and v ~= lp.Character then
            local p = v:FindFirstChild("Torso") or v:FindFirstChild("HumanoidRootPart")
            if p then table.insert(t, {model = v, part = p}) end
        end
    end
    return t
end

task.spawn(function()
    while task.wait(0.2) do
        if config.autoHit then
            local re = findRegisterHitEvent()
            if re then
                local targets = getTargets()
                if #targets > 0 then
                    local hits = {}
                    for _, target in ipairs(targets) do
                        table.insert(hits, {amount = 1, target = target.model, is_friendly = false, part = target.part})
                    end
                    pcall(function() re:FireServer(hits, {}) end)
                end
            end
        end
    end
end)

-- ====== INFINITE AMMO & STAMINA ======
task.spawn(function()
    while task.wait(0.1) do
        local ch = lp.Character
        if ch then
            local hum = ch:FindFirstChild("Humanoid")
            if hum then
                local v = hum:FindFirstChild("Values")
                if v then
                    local stam = v:FindFirstChild("Stamina")
                    if stam and stam:IsA("NumberValue") then
                        if config.infiniteStamina then
                            if not originalStaminaValue then originalStaminaValue = stam.Value end
                            stam.Value = 99999
                        end
                    end
                end
            end
            
            local items = {}
            for _, v in ipairs(ch:GetChildren()) do table.insert(items, v) end
            local bp = lp:FindFirstChild("Backpack")
            if bp then
                for _, v in ipairs(bp:GetChildren()) do table.insert(items, v) end
            end
            
            for _, item in ipairs(items) do
                if item:IsA("Tool") then
                    local wd = item:FindFirstChild("WeaponData")
                    if wd then
                        local e = wd:FindFirstChild("Essentials")
                        if e then
                            local ammo = e:FindFirstChild("Ammo")
                            if ammo and ammo:IsA("NumberValue") then
                                if config.infiniteAmmo then
                                    if not originalAmmoValues[item] then
                                        originalAmmoValues[item] = ammo.Value
                                    end
                                    ammo.Value = 9999
                                end
                            end
                        end
                    end
                end
            end
        end
    end
end)

