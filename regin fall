local highlightObjects = {}
local expandedHitboxes = {}

local function AddHighlight(obj, color, transparency)
   if not obj or not obj.Parent then return end
   pcall(function()
      if not obj:FindFirstChild("TokaiHighlight") then
         local highlight = Instance.new("Highlight")
         highlight.Name = "TokaiHighlight"
         highlight.FillColor = color
         highlight.OutlineColor = color
         highlight.FillTransparency = transparency or 0.3
         highlight.OutlineTransparency = 0
         highlight.Parent = obj
         highlightObjects[obj] = true
      end
   end)
end

local function RemoveHighlight(obj)
   pcall(function()
      local highlight = obj:FindFirstChild("TokaiHighlight")
      if highlight then
         highlight:Destroy()
         highlightObjects[obj] = nil
      end
   end)
end

local function UpdateObjectiveESP()
   if not config.objectiveESP then return end
   local game_workspace = workspace:FindFirstChild("Game")
   if not game_workspace then return end
   local current = game_workspace:FindFirstChild("Current")
   if not current then return end
   local spawned = current:FindFirstChild("Spawned")
   if not spawned then return end
   local gameObjects = spawned:FindFirstChild("GameObjects")
   if not gameObjects then return end
   
   for _, obj in ipairs(gameObjects:GetChildren()) do
      if obj:IsA("Model") and obj.Name:sub(1, 8) == "mission_" then
         AddHighlight(obj, Color3.fromRGB(0, 255, 0), 0.3)
      end
   end
end

local function UpdatePlayerESP()
   if not config.playerESP then return end
   local npcContainer = workspace.Game and workspace.Game.Current and workspace.Game.Current.Spawned and workspace.Game.Current.Spawned.NPCs
   if npcContainer then
      local enemiesFolder = npcContainer:FindFirstChild("enemies")
      if enemiesFolder then
         for _, zombie in ipairs(enemiesFolder:GetChildren()) do
            if zombie:IsA("Model") and zombie:FindFirstChild("Humanoid") then
               AddHighlight(zombie, Color3.fromRGB(255, 0, 0), 0.3)
            end
         end
      end
   end
   for _, player in ipairs(Players:GetPlayers()) do
      if player ~= lp and player.Character then
         local char = player.Character
         if char and char:FindFirstChild("Humanoid") then
            AddHighlight(char, Color3.fromRGB(0, 255, 255), 0.3)
         end
      end
   end
end

local function ClearESP()
   for obj, _ in pairs(highlightObjects) do
      if obj then RemoveHighlight(obj) end
   end
   highlightObjects = {}
end

local function isPlayerCharacter(model)
   if not model or not model:IsA("Model") then return false end
   return Players:GetPlayerFromCharacter(model) ~= nil
end

local function isHumanoidModel(model)
   if not model or not model:IsA("Model") then return false end
   return model:FindFirstChildWhichIsA("Humanoid") ~= nil
end

local function applyHitboxExpander(part)
   if not part or not part:IsA("BasePart") or part.Name ~= "Head" then return end
   local model = part.Parent
   if isHumanoidModel(model) and not isPlayerCharacter(model) then
      part.Size = Vector3.new(config.hitboxSize, config.hitboxSize, config.hitboxSize)
      part.CanCollide = false
      part.Transparency = 0.7
      expandedHitboxes[part] = true
   end
end

local function UpdateHitboxExpander()
   if config.hitboxExpander then
      for _, desc in ipairs(Workspace:GetDescendants()) do
         applyHitboxExpander(desc)
      end
   else
      for part, _ in pairs(expandedHitboxes) do
         expandedHitboxes[part] = nil
      end
      expandedHitboxes = {}
   end
end

Workspace.DescendantAdded:Connect(function(desc)
   if config.hitboxExpander and desc:IsA("BasePart") then
      task.wait(0.05)
      applyHitboxExpander(desc)
   end
end)

local function getEnemyContainer()
   local container = workspace.Game and workspace.Game.Current and workspace.Game.Current.Spawned and workspace.Game.Current.Spawned.NPCs
   if container then return container:FindFirstChild("enemies") end
   return nil
end

local function getClosestHead()
   local container = getEnemyContainer()
   if not container then return nil end
   local referencePos = isMobile and Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2) or UserInputService:GetMouseLocation()
   local bestHeadPos = nil
   local bestDist = math.huge
   for _, enemy in ipairs(container:GetChildren()) do
      local head = enemy:FindFirstChild("Head") or enemy:FindFirstChild("HumanoidRootPart")
      if head then
         local screenPoint, onScreen = camera:WorldToScreenPoint(head.Position)
         if onScreen then
            local dist = (Vector2.new(screenPoint.X, screenPoint.Y) - referencePos).Magnitude
            if dist < bestDist then
               bestDist = dist
               bestHeadPos = head.Position
            end
         end
      end
   end
   return bestHeadPos
end

RunService.Heartbeat:Connect(function()
   if config.raycasting and target.enabled then target.position = getClosestHead() end
   
   if not config.objectiveESP and not config.playerESP then
      ClearESP()
   else
      if config.objectiveESP then UpdateObjectiveESP() end
      if config.playerESP then UpdatePlayerESP() end
   end

   if config.nofog then Lighting.FogEnd = 100000 else Lighting.FogEnd = originalFogEnd end
   if config.fullbright then
      Lighting.Brightness = 3
      Lighting.GlobalShadows = false
   else
      Lighting.Brightness = originalBrightness
      Lighting.GlobalShadows = true
   end
   UpdateHitboxExpander()
end)

local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
   local method = getnamecallmethod()
   if config.raycasting and target.enabled and method:lower() == "raycast" and self == Workspace then
      local args = {...}
      if #args >= 2 and typeof(args[1]) == "Vector3" and typeof(args[2]) == "Vector3" then
         local raycastParams = args[3]
         if raycastParams and raycastParams.CollisionGroup == "raycast_npc_neutral" and target.position then
            local origin = args[1]
            local dir = target.position - origin
            if dir.Magnitude > 0.001 then args[2] = dir.Unit * args[2].Magnitude end
         end
      end
      return oldNamecall(self, unpack(args))
   end
   return oldNamecall(self, ...)
end))

local function getTargets()
   local v11 = {}
   for _, v7 in ipairs(Workspace:GetDescendants()) do
      if v7:IsA("Model") and v7:FindFirstChild("Humanoid") and v7 ~= lp.Character then
         local v12 = v7:FindFirstChild("Torso") or v7:FindFirstChild("HumanoidRootPart")
         if v12 then table.insert(v11, {model = v7, part = v12}) end
      end
   end
   return v11
end

