local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")
local lp = Players.LocalPlayer

local config = {
   infiniteAmmo = false,
   objectiveESP = false, ammoESP = false, armorESP = false, medkitESP = false, playerESP = false,
   hitboxExpander = false, hitboxSize = 6
}

local highlightObjects = {}
local expandedHitboxes = {}

local function AddHighlight(obj, color)
   if not obj or obj:FindFirstChild("TokaiHighlight") then return end
   local h = Instance.new("Highlight")
   h.Name = "TokaiHighlight"
   h.FillColor = color
   h.OutlineColor = color
   h.FillTransparency = 0.3
   h.Parent = obj
   highlightObjects[obj] = true
end

local function RemoveHighlight(obj)
   if obj and obj:FindFirstChild("TokaiHighlight") then
      obj.TokaiHighlight:Destroy()
      highlightObjects[obj] = nil
   end
end

RunService.Heartbeat:Connect(function()
   -- Infinite Ammo
   if config.infiniteAmmo then
      if lp.Backpack then for _, t in ipairs(lp.Backpack:GetChildren()) do if t:IsA("Tool") then pcall(function() t.WeaponData.Essentials.Ammo.Value = 99999 end) end end
      if lp.Character then for _, t in ipairs(lp.Character:GetChildren()) do if t:IsA("Tool") then pcall(function() t.WeaponData.Essentials.Ammo.Value = 99999 end) end end end
   end

   -- ESP Logic
   local gameObjects = workspace:FindFirstChild("Game") and workspace.Game:FindFirstChild("Current") and workspace.Game.Current:FindFirstChild("Spawned") and workspace.Game.Current.Spawned:FindFirstChild("GameObjects")
   
   -- Quét và gỡ bỏ hoặc thêm ESP
   if gameObjects then
      for _, obj in ipairs(gameObjects:GetChildren()) do
         local name = obj.Name
         local color = nil
         if config.objectiveESP and name:sub(1, 8) == "mission_" then color = Color3.fromRGB(0, 255, 0)
         elseif config.ammoESP and name == "pickup_ammo" then color = Color3.fromRGB(255, 255, 0)
         elseif config.armorESP and name == "pickup_armor" then color = Color3.fromRGB(0, 0, 255)
         elseif config.medkitESP and name == "pickup_medkit" then color = Color3.fromRGB(255, 0, 0) end
         
         if color then AddHighlight(obj, color) else RemoveHighlight(obj) end
      end
   end

   -- Hitbox Expander
   if config.hitboxExpander then
      for _, d in ipairs(Workspace:GetDescendants()) do
         if d.Name == "Head" and d.Parent:FindFirstChild("Humanoid") and not Players:GetPlayerFromCharacter(d.Parent) then
            d.Size = Vector3.new(config.hitboxSize, config.hitboxSize, config.hitboxSize)
            d.CanCollide = false
            d.Transparency = 0.7
            expandedHitboxes[d] = true
         end
      end
   else
      for p, _ in pairs(expandedHitboxes) do
         p.Size = Vector3.new(1, 1, 1)
         p.Transparency = 0
         expandedHitboxes[p] = nil
      end
   end
end)

