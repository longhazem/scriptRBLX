local function AddHighlight(obj, color, transparency)
   if not obj or not obj.Parent then return end
   pcall(function()
      if obj:FindFirstChild("TokaiHighlight") then
         obj:FindFirstChild("TokaiHighlight"):Destroy()
      end
      local highlight = Instance.new("Highlight")
      highlight.Name = "TokaiHighlight"
      highlight.FillColor = color
      highlight.OutlineColor = color
      highlight.FillTransparency = transparency or 0.3
      highlight.OutlineTransparency = 0
      highlight.Parent = obj
      highlightObjects[obj] = true
   end)
end

local function RemoveHighlight(obj)
   pcall(function()
      local highlight = obj:FindFirstChild("TokaiHighlight")
      if highlight then
         highlight:Destroy()
         highlightObjects[obj] = nil
      end
   end)
end

local function UpdateObjectiveESP()
   for obj, _ in pairs(highlightObjects) do
      if obj and obj.Parent then
         local name = obj.Name
         if (name:sub(1, 8) == "mission_" or name == "scenery_phone_ringing") and not config.objectiveESP then
            RemoveHighlight(obj)
         elseif name == "pickup_ammo" and not config.ammoESP then
            RemoveHighlight(obj)
         elseif name == "pickup_armor" and not config.armorESP then
            RemoveHighlight(obj)
         elseif name == "pickup_medkit" and not config.medkitESP then
            RemoveHighlight(obj)
         end
      end
   end

   local game_workspace = workspace:FindFirstChild("Game")
   if not game_workspace then return end
   local current = game_workspace:FindFirstChild("Current")
   if not current then return end
   local spawned = current:FindFirstChild("Spawned")
   if not spawned then return end
   local gameObjects = spawned:FindFirstChild("GameObjects")
   if not gameObjects then return end
   
   for _, obj in ipairs(gameObjects:GetChildren()) do
      local name = obj.Name
      local isMission = name:sub(1, 8) == "mission_"
      local isPhone = name == "scenery_phone_ringing"
      local isAmmo = name == "pickup_ammo"
      local isArmor = name == "pickup_armor"
      local isMedkit = name == "pickup_medkit"
      
      if isMission or isPhone or isAmmo or isArmor or isMedkit then
         local shouldHighlight = false
         local color = nil
         
         if (isMission or isPhone) and config.objectiveESP then
            shouldHighlight = true
            if isMission then
               color = Color3.fromRGB(0, 255, 0)
            else
               color = Color3.fromRGB(255, 255, 255)
            end
         elseif isAmmo and config.ammoESP then
            shouldHighlight = true
            color = Color3.fromRGB(255, 255, 0)
         elseif isArmor and config.armorESP then
            shouldHighlight = true
            color = Color3.fromRGB(0, 0, 255)
         elseif isMedkit and config.medkitESP then
            shouldHighlight = true
            color = Color3.fromRGB(255, 0, 0)
         end
         
         if shouldHighlight then
            if not obj:FindFirstChild("TokaiHighlight") then
               AddHighlight(obj, color, 0.3)
            end
         end
      end
   end
end

local function UpdateESP()
   for obj, _ in pairs(highlightObjects) do
      if obj and obj.Parent and obj:FindFirstChild("Humanoid") then
         local isPlayer = Players:GetPlayerFromCharacter(obj) ~= nil
         if isPlayer and not config.playerESP then
            RemoveHighlight(obj)
         elseif not isPlayer and not config.zombieESP then
            RemoveHighlight(obj)
         end
      end
   end
   
   if config.playerESP then
      for _, player in ipairs(Players:GetPlayers()) do
         if player ~= lp and player.Character and player.Character:FindFirstChild("Humanoid") then
            if not player.Character:FindFirstChild("TokaiHighlight") then
               AddHighlight(player.Character, Color3.fromRGB(0, 255, 255), 0.3)
            end
         end
      end
   end

   if config.zombieESP then
      local npcContainer = workspace.Game and workspace.Game.Current and workspace.Game.Current.Spawned and workspace.Game.Current.Spawned.NPCs
      if npcContainer and npcContainer:FindFirstChild("enemies") then
         for _, zombie in ipairs(npcContainer.enemies:GetChildren()) do
            if zombie:IsA("Model") and zombie:FindFirstChild("Humanoid") then
               if not zombie:FindFirstChild("TokaiHighlight") then
                  AddHighlight(zombie, Color3.fromRGB(255, 0, 0), 0.3)
               end
            end
         end
      end
   end
end

local function isPlayerCharacter(model)
   if not model or not model:IsA("Model") then return false end
   return Players:GetPlayerFromCharacter(model) ~= nil
end

local function isHumanoidModel(model)
   if not model or not model:IsA("Model") then return false end
   return model:FindFirstChildWhichIsA("Humanoid") ~= nil
end

local function applyHitboxExpander(part)
   if not part or not part:IsA("BasePart") then return end
   if not config.hitboxExpander then return end
   if part.Name ~= "Head" then return end
   local model = part.Parent
   if isHumanoidModel(model) and not isPlayerCharacter(model) then
      pcall(function()
         if not expandedHitboxes[part] then
            part.Size = Vector3.new(config.hitboxSize, config.hitboxSize, config.hitboxSize)
            part.CanCollide = false
            part.Transparency = 0.7
            expandedHitboxes[part] = true
         else
            part.Size = Vector3.new(config.hitboxSize, config.hitboxSize, config.hitboxSize)
            part.Transparency = 0.7
         end
      end)
   end
end

local function UpdateHitboxExpander()
   if config.hitboxExpander then
      for _, desc in ipairs(Workspace:GetDescendants()) do
         applyHitboxExpander(desc)
      end
   else
      for part, _ in pairs(expandedHitboxes) do
         if part and part.Parent then
            part.Size = Vector3.new(1, 1, 1)
            part.Transparency = 0
         end
         expandedHitboxes[part] = nil
      end
      expandedHitboxes = {}
   end
end

Workspace.DescendantAdded:Connect(function(desc)
   if config.hitboxExpander and desc:IsA("BasePart") then
      task.wait(0.05)
      applyHitboxExpander(desc)
   end
end)

-- Đã xóa toàn bộ hàm getClosestHead, isVisible, getEnemyContainer, hook Raycast, và vòng lặp xoay camera

task.spawn(function()
   while task.wait(0.1) do
      local Character = lp.Character
      if Character then
         local Humanoid = Character:FindFirstChild("Humanoid")
         if Humanoid then
            local Values = Humanoid:FindFirstChild("Values")
            if Values then
               local Stamina = Values:FindFirstChild("Stamina")
               if Stamina and Stamina:IsA("NumberValue") then
                  if config.infiniteStamina then
                     if not originalStaminaValue then
                        originalStaminaValue = Stamina.Value
                     end
                     Stamina.Value = 99999
                  else
                     if originalStaminaValue and Stamina.Value == 99999 then
                        Stamina.Value = originalStaminaValue
                        originalStaminaValue = nil
                     end
                  end
               end
            end
         end
         
         local Backpack = lp:FindFirstChild("Backpack")
         local items = {}
         
         for _, v in ipairs(Character:GetChildren()) do
            table.insert(items, v)
         end
         
         if Backpack then
            for _, v in ipairs(Backpack:GetChildren()) do
               table.insert(items, v)
            end
         end
         
         for _, item in ipairs(items) do
            if item:IsA("Tool") then
               local WeaponData = item:FindFirstChild("WeaponData")
               if WeaponData then
                  local Essentials = WeaponData:FindFirstChild("Essentials")
                  if Essentials then
                     local Ammo = Essentials:FindFirstChild("Ammo")
                     if Ammo and Ammo:IsA("NumberValue") then
                        if config.infiniteAmmo then
                           if originalAmmoValues[item] == nil then
                              originalAmmoValues[item] = Ammo.Value
                           end
                           Ammo.Value = 9999
                        else
                           if originalAmmoValues[item] ~= nil then
                              if Ammo.Value == 9999 then
                                 Ammo.Value = originalAmmoValues[item]
                              end
                              originalAmmoValues[item] = nil
                           end
                        end
                     end
                  end
               end
            end
         end
      end
   end
end)

RunService.Heartbeat:Connect(function()
   if config.nofog then Lighting.FogEnd = 100000 else Lighting.FogEnd = originalFogEnd end
   if config.fullbright then
      Lighting.Brightness = 3
      Lighting.GlobalShadows = false
   else
      Lighting.Brightness = originalBrightness
      Lighting.GlobalShadows = true
   end

   UpdateHitboxExpander()
   UpdateObjectiveESP()
   UpdateESP()
end)

