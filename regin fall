local function CreateESPBox(object, name, color)
    local bbox = Instance.new("BillboardGui")
    bbox.Name = "ESP_" .. name
    bbox.Size = UDim2.new(4, 0, 4, 0)
    bbox.MaxDistance = 500
    bbox.Adornee = object
    local frame = Instance.new("Frame", bbox)
    frame.Size = UDim2.new(1, 0, 1, 0)
    frame.BackgroundTransparency = 1
    frame.BorderSizePixel = 0
    local outline = Instance.new("UIStroke", frame)
    outline.Thickness = 2
    outline.Color = color
    local label = Instance.new("TextLabel", frame)
    label.Size = UDim2.new(1, 0, 0, 20)
    label.BackgroundTransparency = 1
    label.TextColor3 = color
    label.TextScaled = true
    label.Font = Enum.Font.GothamBold
    label.Text = name
    bbox.Parent = object
    return bbox
end

local function UpdateObjectiveESP()
    if not config.objectiveESP then return end
    local game_workspace = Workspace:FindFirstChild("Game")
    if not game_workspace then return end
    local current = game_workspace:FindFirstChild("Current")
    if not current then return end
    local spawned = current:FindFirstChild("Spawned")
    if not spawned then return end
    local gameObjects = spawned:FindFirstChild("GameObjects")
    if not gameObjects then return end
    for _, obj in ipairs(gameObjects:GetChildren()) do
        if obj:IsA("Model") and obj.Name:sub(1, 8) == "mission_" then
            if not espObjects[obj] then
                espObjects[obj] = CreateESPBox(obj, obj.Name, Color3.fromRGB(0, 255, 0))
            end
        end
    end
    for obj, esp in pairs(espObjects) do
        if not obj.Parent then
            esp:Destroy()
            espObjects[obj] = nil
        end
    end
end

local function UpdateZombieESP()
    if not config.zombieESP then return end
    local npcContainer = Workspace.Game and Workspace.Game.Current and Workspace.Game.Current.Spawned and Workspace.Game.Current.Spawned.NPCs
    if npcContainer then
        local enemiesFolder = npcContainer:FindFirstChild("enemies")
        if enemiesFolder then
            for _, zombie in ipairs(enemiesFolder:GetChildren()) do
                if zombie:IsA("Model") and zombie:FindFirstChild("Humanoid") then
                    if not zombieESPObjects[zombie] then
                        zombieESPObjects[zombie] = CreateESPBox(zombie, zombie.Name, Color3.fromRGB(255, 0, 0))
                    end
                end
            end
        end
    end
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= lp and player.Character then
            local char = player.Character
            if char:FindFirstChild("Humanoid") then
                if not zombieESPObjects[char] then
                    zombieESPObjects[char] = CreateESPBox(char, player.Name, Color3.fromRGB(0, 255, 0))
                end
            end
        end
    end
    for obj, esp in pairs(zombieESPObjects) do
        if not obj.Parent then
            esp:Destroy()
            zombieESPObjects[obj] = nil
        end
    end
end

local function isPlayerCharacter(model)
    if not model or not model:IsA("Model") then return false end
    return Players:GetPlayerFromCharacter(model) ~= nil
end

local function isHumanoidModel(model)
    if not model or not model:IsA("Model") then return false end
    return model:FindFirstChildWhichIsA("Humanoid") ~= nil
end

local function applyHitboxExpander(part)
    if not part or not part:IsA("BasePart") then return end
    if not config.hitboxExpander then return end
    if part.Name ~= "Head" then return end
    local model = part.Parent
    if isHumanoidModel(model) and not isPlayerCharacter(model) then
        pcall(function()
            if not expandedHitboxes[part] then
                part.Size = Vector3.new(config.hitboxSize, config.hitboxSize, config.hitboxSize)
                part.CanCollide = false
                part.Transparency = 0.7
                expandedHitboxes[part] = true
            else
                part.Size = Vector3.new(config.hitboxSize, config.hitboxSize, config.hitboxSize)
                part.Transparency = 0.7
            end
        end)
    end
end

local function ResetHitbox(part)
    if not part then return end
    pcall(function() expandedHitboxes[part] = nil end)
end

local function UpdateHitboxExpander()
    if config.hitboxExpander then
        for _, desc in ipairs(Workspace:GetDescendants()) do
            applyHitboxExpander(desc)
        end
    else
        for part, _ in pairs(expandedHitboxes) do
            ResetHitbox(part)
        end
        expandedHitboxes = {}
    end
end

Workspace.DescendantAdded:Connect(function(desc)
    if config.hitboxExpander and desc:IsA("BasePart") then
        task.wait(0.05)
        applyHitboxExpander(desc)
    end
end)

local function AddHighlight(obj, color)
    if not obj or not obj.Parent then return end
    pcall(function()
        if obj:FindFirstChild("Highlight") then
            obj:FindFirstChild("Highlight"):Destroy()
        end
        local highlight = Instance.new("Highlight")
        highlight.FillColor = color
        highlight.OutlineColor = color
        highlight.FillTransparency = 0.3
        highlight.OutlineTransparency = 0
        highlight.Parent = obj
        return highlight
    end)
end

local function RemoveHighlight(obj)
    pcall(function()
        local highlight = obj:FindFirstChild("Highlight")
        if highlight then highlight:Destroy() end
    end)
end

local function UpdateHighlightESP()
    if not config.highlightESP then return end
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("Model") then
            local hum = obj:FindFirstChildOfClass("Humanoid")
            if hum and obj ~= lp.Character then
                local head = obj:FindFirstChild("Head") or obj:FindFirstChild("HumanoidRootPart")
                if head then
                    if not highlightedObjects[obj] then
                        AddHighlight(obj, Color3.fromRGB(255, 0, 0))
                        highlightedObjects[obj] = true
                    end
                end
            end
        end
    end
    local game_workspace = Workspace:FindFirstChild("Game")
    if game_workspace then
        local current = game_workspace:FindFirstChild("Current")
        if current then
            local spawned = current:FindFirstChild("Spawned")
            if spawned then
                local gameObjects = spawned:FindFirstChild("GameObjects")
                if gameObjects then
                    for _, obj in ipairs(gameObjects:GetChildren()) do
                        if obj:IsA("Model") and obj.Name:sub(1, 8) == "mission_" then
                            if not highlightedObjects[obj] then
                                AddHighlight(obj, Color3.fromRGB(0, 255, 0))
                                highlightedObjects[obj] = true
                            end
                        end
                    end
                end
            end
        end
    end
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= lp and player.Character then
            if not highlightedObjects[player.Character] then
                AddHighlight(player.Character, Color3.fromRGB(0, 255, 255))
                highlightedObjects[player.Character] = true
            end
        end
    end
    for obj, _ in pairs(highlightedObjects) do
        if not obj.Parent then
            RemoveHighlight(obj)
            highlightedObjects[obj] = nil
        end
    end
end

local function UpdateWorldMods()
    if config.nofog then
        Lighting.FogEnd = 100000
    else
        Lighting.FogEnd = originalFogEnd
    end
    if config.fullbright then
        Lighting.Brightness = 3
        Lighting.GlobalShadows = false
    else
        Lighting.Brightness = originalBrightness
        Lighting.GlobalShadows = true
    end
end

