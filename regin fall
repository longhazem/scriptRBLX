local MenuGroup = Tabs['UI Settings']:AddLeftGroupbox('Menu')
MenuGroup:AddButton({
    Text = 'Unload',
    Func = function()
        pcall(function()
            FOVCircle:Remove()
        end)
        revertAllHitboxes()
        for obj, _ in pairs(highlightObjects) do
            if obj then
                pcall(function()
                    local highlight = obj:FindFirstChild("TokaiHighlight")
                    if highlight then highlight:Destroy() end
                    local label = obj:FindFirstChild("TokaiNameESP")
                    if label then label:Destroy() end
                end)
            end
        end
        if Library then
            Library:Unload()
        end
    end
})

if ThemeManager then
    ThemeManager:SetLibrary(Library)
end
if SaveManager then
    SaveManager:SetLibrary(Library)
    SaveManager:IgnoreThemeSettings()
    ThemeManager:SetFolder('TokaihHub')
    SaveManager:SetFolder('TokaihHub/reign-fall')
    SaveManager:BuildConfigSection(Tabs['UI Settings'])
    ThemeManager:ApplyToTab(Tabs['UI Settings'])
    SaveManager:LoadAutoloadConfig()
end

if Library then
    Library:OnUnload(function()
        Library.Unloaded = true
    end)
end
