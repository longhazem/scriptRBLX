-- Hàm cập nhật ESP (giữ nguyên)
local function UpdateVisuals(obj, shouldShow, color, nameText)
    if not obj or not obj.Parent then return end
    safePcall(function()
        if shouldShow then
            if not obj:FindFirstChild("TokaiHighlight") then
                local highlight = Instance.new("Highlight")
                highlight.Name = "TokaiHighlight"
                highlight.FillColor = color
                highlight.OutlineColor = color
                highlight.FillTransparency = 0.3
                highlight.OutlineTransparency = 0
                highlight.Parent = obj
                highlightObjects[obj] = true
            end
            local label = obj:FindFirstChild("TokaiNameESP")
            if config.nameESP then
                if not label then
                    label = Instance.new("BillboardGui")
                    label.Name = "TokaiNameESP"
                    label.Size = UDim2.new(0, 200, 0, 50)
                    label.StudsOffset = Vector3.new(0, 3, 0)
                    label.AlwaysOnTop = true
                    local textLabel = Instance.new("TextLabel")
                    textLabel.Parent = label
                    textLabel.Size = UDim2.new(1, 0, 1, 0)
                    textLabel.BackgroundTransparency = 1
                    textLabel.Text = nameText
                    textLabel.TextColor3 = color
                    textLabel.TextStrokeTransparency = 0
                    textLabel.TextSize = 13
                    label.Parent = obj
                else
                    label.TextLabel.Text = nameText
                    label.TextLabel.TextColor3 = color
                end
            else
                if label then label:Destroy() end
            end
        else
            local highlight = obj:FindFirstChild("TokaiHighlight")
            if highlight then highlight:Destroy() end
            local label = obj:FindFirstChild("TokaiNameESP")
            if label then label:Destroy() end
            highlightObjects[obj] = nil
        end
    end)
end

local function UpdateESP()
    local game_workspace = workspace:FindFirstChild("Game")
    if game_workspace then
        local current = game_workspace:FindFirstChild("Current")
        if current then
            local spawned = current:FindFirstChild("Spawned")
            if spawned then
                local gameObjects = spawned:FindFirstChild("GameObjects")
                if gameObjects then
                    for _, obj in ipairs(gameObjects:GetChildren()) do
                        local name = obj.Name
                        if name:sub(1, 8) == "mission_" or name == "scenery_phone_ringing" then
                            local color = name:sub(1, 8) == "mission_" and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 255, 255)
                            UpdateVisuals(obj, config.objectiveESP, color, "Objective")
                        elseif name == "pickup_ammo" then
                            UpdateVisuals(obj, config.ammoESP, Color3.fromRGB(255, 255, 0), "Ammo")
                        elseif name == "pickup_armor" then
                            UpdateVisuals(obj, config.armorESP, Color3.fromRGB(0, 0, 255), "Armor")
                        elseif name == "pickup_medkit" then
                            UpdateVisuals(obj, config.medkitESP, Color3.fromRGB(255, 0, 0), "Medkit")
                        end
                    end
                end
                local npcs = spawned:FindFirstChild("NPCs")
                if npcs and npcs:FindFirstChild("enemies") then
                    for _, zombie in ipairs(npcs.enemies:GetChildren()) do
                        if zombie:IsA("Model") and zombie:FindFirstChild("Humanoid") then
                            UpdateVisuals(zombie, config.zombieESP, Color3.fromRGB(255, 0, 0), "Zombie")
                        end
                    end
                end
            end
        end
    end
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= lp and player.Character and player.Character:FindFirstChild("Humanoid") then
            UpdateVisuals(player.Character, config.playerESP, Color3.fromRGB(0, 255, 255), player.Name)
        end
    end
end

local function isPlayerCharacter(model)
    if not model or not model:IsA("Model") then return false end
    return Players:GetPlayerFromCharacter(model) ~= nil
end

local function isHumanoidModel(model)
    if not model or not model:IsA("Model") then return false end
    return model:FindFirstChildWhichIsA("Humanoid") ~= nil
end

local function applyHitboxExpander(part)
    if not part or not part:IsA("BasePart") then return end
    if not config.hitboxExpander then return end
    if part.Name ~= "Head" then return end
    local model = part.Parent
    if isHumanoidModel(model) and not isPlayerCharacter(model) then
        safePcall(function()
            if not expandedHitboxes[part] then
                part.Size = Vector3.new(config.hitboxSize, config.hitboxSize, config.hitboxSize)
                part.CanCollide = false
                part.Transparency = 0.7
                expandedHitboxes[part] = true
            else
                part.Size = Vector3.new(config.hitboxSize, config.hitboxSize, config.hitboxSize)
                part.Transparency = 0.7
            end
        end)
    end
end

local function UpdateHitboxExpander()
    if config.hitboxExpander then
        for _, desc in ipairs(Workspace:GetDescendants()) do
            applyHitboxExpander(desc)
        end
    else
        for part, _ in pairs(expandedHitboxes) do
            if part and part.Parent then
                part.Size = Vector3.new(1, 1, 1)
                part.Transparency = 0
            end
            expandedHitboxes[part] = nil
        end
        expandedHitboxes = {}
    end
end

Workspace.DescendantAdded:Connect(function(desc)
    if config.hitboxExpander and desc:IsA("BasePart") then
        wait(0.05) -- thay task.wait
        applyHitboxExpander(desc)
    end
end)

local function getEnemyContainer()
    local container = workspace.Game and workspace.Game.Current and workspace.Game.Current.Spawned and workspace.Game.Current.Spawned.NPCs
    if container then
        return container:FindFirstChild("enemies")
    end
    return nil
end

local function isVisible(targetPos)
    if not config.wallcheck then return true end
    local origin = camera.CFrame.Position
    local dir = targetPos - origin
    local raycastParams = RaycastParams.new()
    raycastParams.FilterDescendantsInstances = {lp.Character, camera}
    raycastParams.FilterType = Enum.RaycastFilterType.Exclude
    local result = Workspace:Raycast(origin, dir, raycastParams)
    if result then
        local hitInstance = result.Instance
        if hitInstance:IsDescendantOf(workspace.Game.Current.Spawned.NPCs) then
            return true
        end
        return false
    end
    return true
end

local function getClosestHead()
    local container = getEnemyContainer()
    if not container then return nil end

    local referencePos
    if isMobile then
        local vp = camera.ViewportSize
        referencePos = Vector2.new(vp.X / 2, vp.Y / 2)
    else
        referencePos = UserInputService:GetMouseLocation()
    end

    local bestZombie = nil
    local bestDist = math.huge

    local criticalParts = {"Head", "HumanoidRootPart", "Torso"}

    for _, enemy in ipairs(container:GetChildren()) do
        if not enemy:IsA("Model") then continue end
        if not enemy:FindFirstChild("Humanoid") then continue end

        local headPart = enemy:FindFirstChild("Head")
        if not headPart then
            headPart = enemy:FindFirstChild("HumanoidRootPart") or enemy:FindFirstChild("Torso")
        end
        if not headPart then continue end

        local found = false
        local minDist = math.huge
        for _, partName in ipairs(criticalParts) do
            local part = enemy:FindFirstChild(partName)
            if part and part:IsA("BasePart") then
                local screenPoint, onScreen = camera:WorldToScreenPoint(part.Position)
                if onScreen then
                    local dist = (Vector2.new(screenPoint.X, screenPoint.Y) - referencePos).Magnitude
                    if dist <= config.fovSize and dist <= config.aimbotRange then
                        if dist < minDist then minDist = dist end
                        found = true
                    end
                end
            end
        end

        if found and minDist < bestDist then
            if config.wallcheck and not isVisible(headPart.Position) then
                continue
            end
            bestDist = minDist
            bestZombie = enemy
        end
    end

    if bestZombie then
        local head = bestZombie:FindFirstChild("Head")
        if head then
            return head.Position
        else
            local root = bestZombie:FindFirstChild("HumanoidRootPart") or bestZombie:FindFirstChild("Torso")
            if root then return root.Position end
        end
    end
    return nil
end

-- Render loop dùng wait để tương thích
local function renderLoop()
    while true do
        wait(0.03) -- thay cho RenderStepped nếu không có
        if (config.raycasting or config.aimbot) and target.enabled then
            target.position = getClosestHead()
        end
        if config.aimbot and target.position then
            camera.CFrame = CFrame.new(camera.CFrame.Position, target.position)
        end
        if config.fovEnabled and FOVCircle then
            FOVCircle.Visible = true
            FOVCircle.Radius = config.fovSize
            if isMobile then
                FOVCircle.Position = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y / 2)
            else
                FOVCircle.Position = UserInputService:GetMouseLocation()
            end
        elseif FOVCircle then
            FOVCircle.Visible = false
        end
        UpdateESP()
    end
end

-- Chạy loop trong một coroutine
coroutine.wrap(renderLoop)()

-- Hook raycast cho silent aim (nếu hỗ trợ hookmetamethod)
local oldNamecall = nil
if hookmetamethod and getnamecallmethod and newcclosure then
    oldNamecall = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
        local method = getnamecallmethod()
        if config.raycasting and target.enabled and method:lower() == "raycast" and self == Workspace then
            local args = {...}
            if #args >= 2 and typeof(args[1]) == "Vector3" and typeof(args[2]) == "Vector3" then
                local raycastParams = args[3]
                if raycastParams and raycastParams.CollisionGroup == "raycast_npc_neutral" then
                    if target.position then
                        local origin = args[1]
                        local dir = target.position - origin
                        if dir.Magnitude > 0.001 then
                            args[2] = dir.Unit * args[2].Magnitude
                        end
                    end
                end
            end
            return oldNamecall(self, unpack(args))
        end
        return oldNamecall(self, ...)
    end))
else
    warn("[TokaiHub] hookmetamethod không hỗ trợ, silent aim sẽ không hoạt động")
end

local function findRegisterHitEvent()
    local v3 = lp.Character
    if not v3 then return nil end
    for v2, v4 in ipairs(v3:GetChildren()) do
        local v9 = v4:FindFirstChild("ServerEvents")
        if v9 then
            local v8 = v9:FindFirstChild("RegisterHit")
            if v8 and v8:IsA("RemoteEvent") then
                return v8
            end
        end
    end
    return nil
end

local function getTargets()
    local v11 = {}
    for v2, v7 in ipairs(Workspace:GetDescendants()) do
        if v7:IsA("Model") and v7:FindFirstChild("Humanoid") and v7 ~= lp.Character then
            local v12 = v7:FindFirstChild("Torso") or v7:FindFirstChild("HumanoidRootPart")
            if v12 then
                table.insert(v11, {model = v7, part = v12})
            end
        end
    end
    if #v11 == 0 and typeof(getnilinstances) == "function" then
        for v2, v7 in ipairs(getnilinstances()) do
            if v7:IsA("Model") then
                local v12 = v7:FindFirstChild("Torso") or v7:FindFirstChild("HumanoidRootPart")
                if v12 then
                    table.insert(v11, {model = v7, part = v12})
                end
            end
        end
    end
    return v11
end

coroutine.wrap(function()
    while true do
        wait(0.2)
        if config.autoHit then
            local v5 = findRegisterHitEvent()
            if v5 then
                local v11 = getTargets()
                if #v11 > 0 then
                    local v6 = {}
                    for v2, v10 in ipairs(v11) do
                        table.insert(v6, {amount = 1, target = v10.model, is_friendly = false, part = v10.part})
                    end
                    if #v6 > 0 then
                        v5:FireServer(v6, {})
                    end
                end
            end
        end
    end
end)()

coroutine.wrap(function()
    while true do
        wait(0.1)
        local Character = lp.Character
        if Character then
            local Humanoid = Character:FindFirstChild("Humanoid")
            if Humanoid then
                local Values = Humanoid:FindFirstChild("Values")
                if Values then
                    local Stamina = Values:FindFirstChild("Stamina")
                    if Stamina and Stamina:IsA("NumberValue") then
                        if config.infiniteStamina then
                            if not originalStaminaValue then
                                originalStaminaValue = Stamina.Value
                            end
                            Stamina.Value = 99999
                        else
                            if originalStaminaValue and Stamina.Value == 99999 then
                                Stamina.Value = originalStaminaValue
                                originalStaminaValue = nil
                            end
                        end
                    end
                end
            end
            local Backpack = lp:FindFirstChild("Backpack")
            local items = {}
            for _, v in ipairs(Character:GetChildren()) do
                table.insert(items, v)
            end
            if Backpack then
                for _, v in ipairs(Backpack:GetChildren()) do
                    table.insert(items, v)
                end
            end
            for _, item in ipairs(items) do
                if item:IsA("Tool") then
                    local WeaponData = item:FindFirstChild("WeaponData")
                    if WeaponData then
                        local Essentials = WeaponData:FindFirstChild("Essentials")
                        if Essentials then
                            local Ammo = Essentials:FindFirstChild("Ammo")
                            if Ammo and Ammo:IsA("NumberValue") then
                                if config.infiniteAmmo then
                                    if originalAmmoValues[item] == nil then
                                        originalAmmoValues[item] = Ammo.Value
                                    end
                                    Ammo.Value = 9999
                                else
                                    if originalAmmoValues[item] ~= nil then
                                        if Ammo.Value == 9999 then
                                            Ammo.Value = originalAmmoValues[item]
                                        end
                                        originalAmmoValues[item] = nil
                                    end
                                end
                            end
                        end
                    end
                end
            end
        end
    end
end)()

