local expandedHitboxes = {}

-- Functions ESP & Hitbox
local function AddHighlight(obj, color, transparency)
   if not obj or not obj.Parent or obj:FindFirstChild("TokaiHighlight") then return end
   local highlight = Instance.new("Highlight")
   highlight.Name = "TokaiHighlight"
   highlight.FillColor = color
   highlight.OutlineColor = color
   highlight.FillTransparency = transparency or 0.3
   highlight.OutlineTransparency = 0
   highlight.Parent = obj
   highlightObjects[obj] = true
end

local function RemoveHighlight(obj)
   local highlight = obj and obj:FindFirstChild("TokaiHighlight")
   if highlight then highlight:Destroy(); highlightObjects[obj] = nil end
end

local function UpdateESP()
   -- Objective & Items
   local gameObjects = workspace:FindFirstChild("Game") and workspace.Game:FindFirstChild("Current") and workspace.Game.Current:FindFirstChild("Spawned") and workspace.Game.Current.Spawned:FindFirstChild("GameObjects")
   if gameObjects then
      for _, obj in ipairs(gameObjects:GetChildren()) do
         local name = obj.Name
         local color = nil
         if config.objectiveESP and name:sub(1, 8) == "mission_" then color = Color3.fromRGB(0, 255, 0)
         elseif config.ammoESP and name == "pickup_ammo" then color = Color3.fromRGB(255, 255, 0)
         elseif config.armorESP and name == "pickup_armor" then color = Color3.fromRGB(0, 0, 255)
         elseif config.medkitESP and name == "pickup_medkit" then color = Color3.fromRGB(255, 0, 0) end
         if color then AddHighlight(obj, color, 0.3) end
      end
   end
   -- Player ESP
   if config.playerESP then
      local npcs = workspace:FindFirstChild("Game") and workspace.Game:FindFirstChild("Current") and workspace.Game.Current:FindFirstChild("Spawned") and workspace.Game.Current.Spawned:FindFirstChild("NPCs")
      if npcs then
         for _, enemy in ipairs(npcs:FindFirstChild("enemies"):GetChildren()) do if enemy:FindFirstChild("Humanoid") then AddHighlight(enemy, Color3.fromRGB(255, 0, 0), 0.3) end end
      end
      for _, p in ipairs(Players:GetPlayers()) do if p ~= lp and p.Character and p.Character:FindFirstChild("Humanoid") then AddHighlight(p.Character, Color3.fromRGB(0, 255, 255), 0.3) end end
   end
end

local function applyHitbox(part)
   if config.hitboxExpander and part.Name == "Head" and part.Parent:FindFirstChild("Humanoid") and Players:GetPlayerFromCharacter(part.Parent) == nil then
      part.Size = Vector3.new(config.hitboxSize, config.hitboxSize, config.hitboxSize)
      part.CanCollide = false
      part.Transparency = 0.7
      expandedHitboxes[part] = true
   end
end

-- Core Loops
RunService.Heartbeat:Connect(function()
   -- Ammo
   if config.infiniteAmmo then
      for _, t in ipairs(lp.Backpack:GetChildren()) do if t:IsA("Tool") then pcall(function() t.WeaponData.Essentials.Ammo.Value = 99999 end) end end
      if lp.Character then for _, t in ipairs(lp.Character:GetChildren()) do if t:IsA("Tool") then pcall(function() t.WeaponData.Essentials.Ammo.Value = 99999 end) end end end
   end
   -- ESP & Hitbox
   if not config.objectiveESP and not config.ammoESP and not config.armorESP and not config.medkitESP and not config.playerESP then
      for obj, _ in pairs(highlightObjects) do RemoveHighlight(obj) end
   else UpdateESP() end
   if config.hitboxExpander then for _, d in ipairs(Workspace:GetDescendants()) do applyHitbox(d) end else for p, _ in pairs(expandedHitboxes) do p.Size = Vector3.new(1, 1, 1); p.Transparency = 0; expandedHitboxes[p] = nil end end
end)

