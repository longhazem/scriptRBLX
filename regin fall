local highlightObjects = {}
local expandedHitboxes = {}

local function AddHighlight(obj, color, transparency)
   if not obj or not obj.Parent then return end
   pcall(function()
      if not obj:FindFirstChild("TokaiHighlight") then
         local highlight = Instance.new("Highlight")
         highlight.Name = "TokaiHighlight"
         highlight.FillColor = color
         highlight.OutlineColor = color
         highlight.FillTransparency = transparency or 0.3
         highlight.OutlineTransparency = 0
         highlight.Parent = obj
         highlightObjects[obj] = true
      end
   end)
end

local function RemoveHighlight(obj)
   pcall(function()
      local highlight = obj:FindFirstChild("TokaiHighlight")
      if highlight then
         highlight:Destroy()
         highlightObjects[obj] = nil
      end
   end)
end

local function UpdateObjectiveESP()
   local game_workspace = workspace:FindFirstChild("Game")
   if not game_workspace then return end
   local current = game_workspace:FindFirstChild("Current")
   if not current then return end
   local spawned = current:FindFirstChild("Spawned")
   if not spawned then return end
   local gameObjects = spawned:FindFirstChild("GameObjects")
   if not gameObjects then return end
   
   for _, obj in ipairs(gameObjects:GetChildren()) do
      local name = obj.Name
      local shouldHighlight = false
      local color = Color3.fromRGB(255, 255, 255)

      if config.objectiveESP and name:sub(1, 8) == "mission_" then shouldHighlight = true; color = Color3.fromRGB(0, 255, 0)
      elseif config.ammoESP and name == "pickup_ammo" then shouldHighlight = true; color = Color3.fromRGB(255, 255, 0)
      elseif config.armorESP and name == "pickup_armor" then shouldHighlight = true; color = Color3.fromRGB(0, 0, 255)
      elseif config.medkitESP and name == "pickup_medkit" then shouldHighlight = true; color = Color3.fromRGB(255, 0, 0) end

      if shouldHighlight then AddHighlight(obj, color, 0.3) end
   end
end

local function UpdatePlayerESP()
   if not config.playerESP then return end
   local npcContainer = workspace.Game and workspace.Game.Current and workspace.Game.Current.Spawned and workspace.Game.Current.Spawned.NPCs
   if npcContainer then
      local enemiesFolder = npcContainer:FindFirstChild("enemies")
      if enemiesFolder then
         for _, zombie in ipairs(enemiesFolder:GetChildren()) do
            if zombie:IsA("Model") and zombie:FindFirstChild("Humanoid") then
               AddHighlight(zombie, Color3.fromRGB(255, 0, 0), 0.3)
            end
         end
      end
   end
   for _, player in ipairs(Players:GetPlayers()) do
      if player ~= lp and player.Character then
         local char = player.Character
         if char and char:FindFirstChild("Humanoid") then
            AddHighlight(char, Color3.fromRGB(0, 255, 255), 0.3)
         end
      end
   end
end

local function ClearESP()
   for obj, _ in pairs(highlightObjects) do
      if obj then RemoveHighlight(obj) end
   end
   highlightObjects = {}
end

RunService.Heartbeat:Connect(function()
   if not config.objectiveESP and not config.ammoESP and not config.armorESP and not config.medkitESP and not config.playerESP then
      ClearESP()
   else
      UpdateObjectiveESP()
      UpdatePlayerESP()
   end

   if config.nofog then Lighting.FogEnd = 100000 else Lighting.FogEnd = originalFogEnd end
   if config.fullbright then Lighting.Brightness = 3; Lighting.GlobalShadows = false else Lighting.Brightness = originalBrightness; Lighting.GlobalShadows = true end
end)

